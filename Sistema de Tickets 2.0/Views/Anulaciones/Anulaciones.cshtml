@model List<Capa_Entidad.Anulaciones.E_Anulaciones>
@using Capa_Entidad.Anulaciones

@{
    ViewData["Title"] = "Anulaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    /* Estilos para el Chat */
    #chatBox {
        height: 350px;
        overflow-y: auto;
        background-color: #f8f9fa;
        display: flex;
        flex-direction: column;
        padding: 15px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        gap: 12px;
    }

    .chat-message {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 10px;
        position: relative;
        font-size: 0.9rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .chat-left {
        align-self: flex-start;
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        color: #333;
    }

    .chat-right {
        align-self: flex-end;
        background-color: #0d6efd;
        color: white;
    }

    .chat-time {
        font-size: 0.65rem;
        display: block;
        margin-top: 4px;
        opacity: 0.7;
    }

    .chat-user {
        font-size: 0.7rem;
        font-weight: bold;
        display: block;
        margin-bottom: 2px;
    }

    .notif-badge {
        font-size: 0.6rem;
        padding: 4px 6px;
        margin-left: 5px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>

<div class="container-fluid mt-3">
    <div class="row">
        @* --- LISTADO DE ANULACIONES --- *@
        <div class="col-md-6 border-end">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-ticket-alt"></i> Listado de Tickets</h2>
                <button class="btn btn-primary shadow-sm" onclick="abrirModalNuevo()">
                    <i class="fas fa-plus-circle"></i> Nuevo Registro
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover shadow-sm border" id="tblTickets">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Solicitante</th>
                            <th>Incidencia</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr id="row-@t.IdAnulacion">
                                <td>
                                    <span class="fw-bold">@t.IdAnulacion</span>
                                    <span id="notif-@t.IdAnulacion" class="badge rounded-pill bg-danger d-none notif-badge">
                                        <i class="fas fa-comment"></i>
                                    </span>
                                </td>
                                <td>@t.UsuarioSolicitador</td>
                                <td>@t.Incidencia</td>
        
                                <td>@t.Registro</td>
                                <td>
                                    <span class="badge @(t.Estado == "Pendiente" ? "bg-warning text-dark" : (t.Estado == "Cerrado" ? "bg-success" : "bg-info"))">
                                        @t.Estado
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary btn-ver" data-info='@Json.Serialize(t)'>
                                        <i class="fas fa-eye"></i> Ver
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* --- DETALLE DEL TICKET --- *@
        <div class="col-md-6 bg-light p-4" id="seccionDetalle" style="display:none; min-height: 85vh;">
            <ul class="nav nav-tabs" id="ticketTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#info" type="button">
                        <i class="fas fa-info-circle"></i> Gestión
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-bold" id="tabChat" data-bs-toggle="tab" data-bs-target="#chatTab" type="button" onclick="marcarComoLeido(); cargarComentarios(); iniciarRefrescoChat();">
                        <i class="fas fa-comments"></i> Chat / Notas
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#adjuntosTab" type="button">
                        <i class="fas fa-paperclip"></i> Adjuntos
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-4 bg-white shadow-sm">
                @* Pestaña Información *@
                <div class="tab-pane fade show active" id="info">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-primary m-0"> #<span id="lblIdTicket"></span></h5>
                        <span id="badgeEstado" class="badge p-2"></span>
                    </div>

                    <div class="row g-2 mb-4 border-bottom pb-3">
                        <div class="col-6 small"><strong>Solicitante:</strong> <span id="txtSolicitante" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Incidencia:</strong> <span id="txtIncidencia" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Técnico:</strong> <span id="txtAsignado" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Caja:</strong> <span id="txtCaja" class="d-block text-muted"></span></div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small text-success">Resolución Técnica:</label>
                        <textarea id="txtResolucion" class="form-control border-success" rows="4"></textarea>
                    </div>

                    <div class="d-flex justify-content-between mb-4 small text-muted">
                        <span>Registro: <b id="lblRegistro"></b></span>
                        <span>Modif: <b id="lblModif"></b></span>
                    </div>

                    <div id="contenedorBotonGuardar">
                        <button id="btnGuardarTicket" class="btn btn-success w-100" onclick="guardarCambiosTicket()">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                </div>

                @* Pestaña Chat *@
                <div class="tab-pane fade" id="chatTab">
                    <div id="chatBox"></div>
                    <div id="divPreviewChat" class="mt-2" style="display:none;">
                        <span class="badge bg-info text-dark">
                            <i class="fas fa-paperclip"></i> <span id="lblNombreArchivoChat"></span>
                            <i class="fas fa-times ms-2" style="cursor:pointer" onclick="limpiarArchivoChat()"></i>
                        </span>
                    </div>
                    <div class="input-group mt-3" id="contenedorEscrituraChat">
                        <input type="file" id="fArchivoChat" style="display:none" onchange="seleccionarArchivoChat(this)" />
                        <button class="btn btn-outline-secondary" type="button" onclick="$('#fArchivoChat').click()">
                            <i class="fas fa-paperclip"></i>
                        </button>
                        <input type="text" id="txtMensajeChat" class="form-control" placeholder="Escribe un comentario..." onkeypress="if(event.keyCode==13) enviarComentario()">
                        <button class="btn btn-primary" type="button" onclick="enviarComentario()">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>

                @* Pestaña Adjuntos *@
                <div class="tab-pane fade" id="adjuntosTab">
                    <h6 class="fw-bold mb-3">Archivos cargados al crear ticket:</h6>
                    <div id="listaAdjuntos" class="list-group list-group-flush border mb-3"></div>
                </div>
            </div>
        </div>

        <div class="col-md-6 d-flex align-items-center justify-content-center bg-light border" id="detalleVacio" style="min-height: 85vh;">
            <div class="text-center text-muted">
                <i class="fas fa-mouse-pointer fa-3x mb-3"></i>
                <p>Selecciona un ticket de la lista para ver el detalle</p>
            </div>
        </div>
    </div>
</div>

@* --- MODAL NUEVO  --- *@
<div class="modal fade" id="modalNuevoTicket" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-plus-circle"></i> Nuevo </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Tipo de Incidencia</label>
                    <select id="cboIncidencia" class="form-select border-primary">
                        @foreach (var item in ViewBag.Incidencias)
                        {
                            <option value="@item.IdTiposIncidenciasAnulaciones">@item.Descripcion</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Caja / Ubicación</label>
                    <select id="cboCaja" class="form-select">
                        <option value="0">-- Sin Caja / No aplica --</option>
                        @foreach (var item in ViewBag.Cajas)
                        {
                            <option value="@item.IdCaja">@item.Descripcion</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase text-primary">
                        <i class="fas fa-paperclip"></i> Adjuntar Archivos y Videos (Opcional)
                    </label>
                    <input type="file" id="fArchivos" class="form-control" multiple
                           accept="image/*,video/mp4,video/x-m4v,video/*,.pdf,.doc,.docx,.xls,.xlsx" />
                    <div class="form-text" style="font-size: 0.75rem;">
                        Puedes subir imágenes, documentos o videos cortos (MP4).
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-muted" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary px-4" onclick="crearTicket()">Crear </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {



    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let memoriaArchivos = new DataTransfer();
        let ultimaCantidadComentarios = 0;
        // --- 1. VARIABLES GLOBALES Y ESTADO ---
        let Seleccionado = null;      // Guarda el objeto del ticket que se está viendo
        let chatTimer = null;               // Timer para refrescar el chat cada 3 segundos
        let tituloOriginal = document.title;// Guarda "Tickets - Mi Sistema"
        let intervaloPestaña = null;        // Timer para el parpadeo del título
        let ultimoIdComentarioVisto = {};   // Diccionario { idTicket: ultimoIdChat } para badges rojos
        let versionTicketsActual = "";      // Sello de versión (ej: "12-48") para detectar cambios

        // Datos de sesión desde C#
        const idUsuarioLogueado = parseInt('@ViewBag.IdUsuarioLogueado') || 0;
        const nombreTecnicoLogueado = '@ViewBag.NombreUsuarioLogueado';
        const rolUsuarioLogueado = parseInt('@ViewBag.RolUsuario') || 0;


 


        $(document).ready(function () {
            // 1. Inicializar DataTable
            $('#tblTickets').DataTable({
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50],
                order: [],
                language: {
                    lengthMenu: "Mostrar _MENU_ registros",
                    zeroRecords: "No se encontraron datos",
                    info: "Página _PAGE_ de _PAGES_",
                    infoEmpty: "No hay registros",
                    infoFiltered: "(filtrado de _MAX_ registros)",
                    search: "Buscar:",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                }
            });
            // Detectar cuando el usuario cambia a la pestaña de Chat
            $('button[data-bs-target="#chat"]').on('shown.bs.tab', function (e) {
                marcarComoLeido();
            });
            // 2. Ejecutar revisiones iniciales
            actualizarVersionBaseDatos();
            sincronizarEstadosChatMasivo(); // Reemplaza al antiguo .each()

            // 3. Configurar Monitores (Timers)
            setInterval(verificarCambios, 10000);
            setInterval(sincronizarEstadosChatMasivo, 6000); // El monitor ahora es masivo
        });

        // --- FUNCIONES REFACTORIZADAS ---

        function actualizarVersionBaseDatos() {
            // Apuntamos a Anulaciones para mantener la consistencia
            $.get('@Url.Action("ObtenerVersionReclamos", "Anulaciones")', function (v) {
                versionTicketsActual = v;
            });
        }

        function sincronizarEstadosChatMasivo() {
            let idsAnulaciones = [];

            // Recolectamos todos los IDs de la tabla (Anulaciones)
            $(".btn-ver").each(function () {
                let info = $(this).data("info");
                let id = info.IdAnulacion || info.idAnulacion;
                if (id) idsAnulaciones.push(id);
            });

            if (idsAnulaciones.length === 0) return;

            $.ajax({
                url: '@Url.Action("ObtenerEstadosChats", "Anulaciones")', // Asegúrate que exista en AnulacionesController
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(idsAnulaciones),
                success: function (estados) {
                    estados.forEach(res => {
                        const id = res.idAnulacion || res.idTicket; // Soporte para ambos nombres de propiedad
                        const clave = `visto_anulacion_u${idUsuarioLogueado}_a${id}`;
                        const guardado = localStorage.getItem(clave);
                        const ultimoVisto = guardado ? parseInt(guardado) : 0;

                        // Usamos "Seleccionado" que es tu variable global
                        const abiertoId = Seleccionado?.IdAnulacion || Seleccionado?.idAnulacion;
                        const estaViendoChat = (id === abiertoId && $("#chatTab").hasClass("active"));

                        if (estaViendoChat) {
                            localStorage.setItem(clave, res.ultimoId);
                            $(`#notif-${id}`).addClass("d-none");
                        }
                        else if (res.ultimoId > ultimoVisto && res.idAutor !== idUsuarioLogueado) {
                            $(`#notif-${id}`).removeClass("d-none");
                        } else {
                            $(`#notif-${id}`).addClass("d-none");
                        }

                        ultimoIdComentarioVisto[id] = Math.max(res.ultimoId, ultimoVisto);
                    });
                }
            });
        }

        // --- 4. FUNCIÓN: DETECTAR CAMBIOS EN EL SERVIDOR (Para todos los usuarios) ---
        function verificarCambios() {
            // Quitamos el IF de rolUsuarioLogueado para que el Solicitante también actualice
            $.get('@Url.Action("ObtenerVersionReclamos", "Anulaciones")', function (nuevaVersion) {

                // Si el sello "Conteo-Suma" cambió, algo pasó en la DB
                if (versionActual !== "" && nuevaVersion !== versionActual) {
                    versionActual = nuevaVersion;

                    refrescarTablaTickets(); // Actualiza la tabla sin F5

                    // Notificamos visualmente en la pestaña solo si no es el usuario que está mirando el detalle
                    if (!intervaloPestaña) {
                        intervaloPestaña = setInterval(() => {
                            document.title = (document.title === tituloOriginal) ? "✨ ACTUALIZACIÓN ✨" : tituloOriginal;
                        }, 1000);
                    }

                    // Si el usuario tenía un ticket abierto y este cambió, actualizamos los datos del detalle
                    if (Seleccionado) {
                        const idAbierto = Seleccionado.IdAnulacion || Seleccionado.idAnulacion;
                        // Buscamos el botón de ese ticket en la nueva tabla para obtener su nueva data
                        const $btnNuevo = $(`.btn-ver[data-info*='"idTicket":${idAbierto}']`).first()
                                       || $(`.btn-ver[data-info*='"IdTicket":${idAbierto}']`).first();

                        if ($btnNuevo.length > 0) {
                            Seleccionado = $btnNuevo.data("info");
                            // Opcional: podrías llamar a verDetalle(ticketSeleccionado)
                            // si quieres que los badges y botones cambien al instante
                        }
                    }
                }
            });
        }

        // --- 5. FUNCIÓN: REFRESCO SILENCIOSO DE TABLA ---
        function refrescarTablaTickets() {
            // Pedimos el HTML de la página actual por debajo
            $.get(window.location.href, function (data) {
                // Extraemos solo el contenido del <tbody> de la respuesta
                const nuevoContenido = $(data).find("#tblTickets tbody").html();
                // Lo reemplazamos en nuestra tabla visible
                $("#tblTickets tbody").html(nuevoContenido);
                console.log("Tabla actualizada dinámicamente.");
            });
        }

        // --- 6. EVENTO: VER DETALLE (CLICK EN TABLA) ---
        $(document).on("click", ".btn-ver", function () {
            let $btn = $(this);
            let info = $btn.data("info");
            const idAnulacion = info.IdAnulacion || info.idAnulacion;

            // Al hacer click, limpiamos el aviso parpadeante del título
            if (intervaloPestaña) {
                clearInterval(intervaloPestaña);
                intervaloPestaña = null;
                document.title = tituloOriginal;
            }

            const idAsignadoActual = info.IdUsuarioAsignado || info.idUsuarioAsignado;

            // Auto-asignación: Si no tiene técnico y yo soy Staff
            if ((!idAsignadoActual || idAsignadoActual === 0) && (rolUsuarioLogueado === 1 || rolUsuarioLogueado === 3)) {
                $.post('@Url.Action("TomarAnulacion", "Anulaciones")', { idAnulacion: idAnulacion }, function (res) {
                    if (res.success) {
                        // Actualizamos el objeto local y la fila visualmente
                        info.IdEstado = 5;
                        info.Estado = "En Proceso";
                        info.IdUsuarioAsignado = idUsuarioLogueado;
                        info.UsuarioAsignado = nombreTecnicoLogueado;
                        $btn.data("info", info);
                        $btn.closest("tr").find(".badge").first().text("En Proceso").attr("class", "badge bg-info");
                    }
                    verDetalle(info);
                });
            } else {
                verDetalle(info);
            }
        });

        function verDetalle(anulacion) {
            if (!anulacion) return;
            if (chatTimer) clearInterval(chatTimer);

            // --- LIMPIEZA FORZADA DE CAMPOS ---
            // Esto asegura que no veas lo del ticket anterior mientras carga el nuevo
            $("#txtResolucion").val("");
            $("#chatBox").html("");

            Seleccionado = anulacion;

            $("#seccionDetalle").show();
            $("#detalleVacio").hide();

            // Reset a la primera pestaña (Información)
            const firstTab = new bootstrap.Tab(document.querySelector('#ticketTabs button[data-bs-target="#info"]'));
            firstTab.show();

            const id = anulacion.idAnulacion || anulacion.IdAnulacion;
            const estado = anulacion.estado || anulacion.Estado;
            const idAsignado = anulacion.idUsuarioAsignado || anulacion.IdUsuarioAsignado;
            const esStaff = (rolUsuarioLogueado === 1 || rolUsuarioLogueado === 3);

            const formatearFecha = (f) => {
                if (!f) return "N/A";
                let d = new Date(f);
                return isNaN(d) ? f : d.toLocaleString();
            };

            // Llenado de etiquetas (Usamos .text para labels y .val para textareas)
            $("#lblIdTicket").text(id);
            $("#txtSolicitante").text(anulacion.usuarioSolicitador || anulacion.UsuarioSolicitador || "N/A");
            $("#txtIncidencia").text(anulacion.incidencia || anulacion.Incidencia || "N/A");
            $("#txtCaja").text(anulacion.caja || anulacion.Caja || "N/A");
            $("#txtAsignado").text(anulacion.usuarioAsignado || anulacion.UsuarioAsignado || "N/A");
            $("#lblRegistro").text(formatearFecha(anulacion.registro || anulacion.Registro));
            $("#lblModif").text(formatearFecha(anulacion.modificacion || anulacion.Modificacion));

            // IMPORTANTE: Usar .val() para que el textarea se refresque correctamente
            $("#txtResolucion").val(anulacion.resolucion || anulacion.Resolucion || "");

            // Badge de estado
            let colorClass = (estado === "Pendiente") ? "bg-warning text-dark" : (estado === "Cerrado" ? "bg-success" : "bg-info");
            $("#badgeEstado").text(estado).removeClass("bg-warning bg-info bg-success text-dark").addClass(colorClass);
            // --- LÓGICA PARA DESHABILITAR CHAT SI EL TICKET ESTÁ CERRADO ---
            if (estado === "Cerrado") {
                bloquearChatVisualmente();
                $(".btn-primary[onclick='enviarComentario()']").prop("disabled", true);
                $("#fArchivoChat").prop("disabled", true); // También deshabilitamos el input de archivos
                $(".fa-paper-plane").closest("button").addClass("btn-secondary").removeClass("bg-primary"); // Cambio visual opcional
            } else {
                $("#txtMensajeChat").prop("disabled", false).attr("placeholder", "Escribe un comentario...");
                $(".btn-primary[onclick='enviarComentario()']").prop("disabled", false);
                $("#fArchivoChat").prop("disabled", false);
                $(".fa-paper-plane").closest("button").addClass("btn-primary").removeClass("btn-secondary");
            }
            // Lógica de Seguridad para edición
            let puedeEditar = (estado !== "Cerrado" && (rolUsuarioLogueado === 1 || idAsignado === idUsuarioLogueado));
            if (puedeEditar) {
                $("#btnGuardarTicket").show();
                $("#txtResolucion, #txtDetalleProblema").prop("readonly", false).removeClass("bg-light");
            } else {
                $("#btnGuardarTicket").hide();
                $("#txtResolucion, #txtDetalleProblema").prop("readonly", true).addClass("bg-light");
            }

            // Carga de chat y adjuntos
            ultimaCantidadComentarios = 0;
            actualizarChatSilencioso();
            marcarComoLeido();
            cargarAdjuntos(id);
        }
        // --- 7. FUNCIONES DE CHAT ---

        function marcarComoLeido() {
            if (!Seleccionado) return;
            const id = Seleccionado.IdAnulacion || Seleccionado.idAnulacion;

            $(`#notif-${id}`).addClass("d-none");

            $.get('@Url.Action("ObtenerUltimoComentarioId", "Anulaciones")', { idAnulacion: id }, function (res) {
                const clave = `visto_anulacion_u${idUsuarioLogueado}_a${id}`;
                localStorage.setItem(clave, res.ultimoId);
                ultimoIdComentarioVisto[id] = res.ultimoId;
            });
        }

        function iniciarRefrescoChat() {
            if (chatTimer) clearInterval(chatTimer);
            chatTimer = setInterval(() => {
                if ($("#chatTab").hasClass("active")) actualizarChatSilencioso();
            }, 3000);
        }





        function actualizarChatSilencioso() {
            if (!Seleccionado) return;
            const idAnulacion = Seleccionado.IdAnulacion || Seleccionado.idAnulacion;

            $.get('@Url.Action("ObtenerComentarios", "Anulaciones")', { idAnulacion: idAnulacion }, function (data) {

                // 1. Manejo de estado vacío (Quitar spinner o limpiar mensajes previos)
                if (data.length === 0) {
                    if (ultimaCantidadComentarios !== 0 || $("#chatBox").find(".fa-spinner").length > 0) {
                        $("#chatBox").html('<div class="text-center text-muted small mt-4">No hay comentarios en esta anulación.</div>');
                        ultimaCantidadComentarios = 0;
                    }
                    return;
                }

                // 2. Evitar re-dibujar el DOM si no hay mensajes nuevos
                if (data.length === ultimaCantidadComentarios) return;

                let html = "";
                data.forEach(c => {
                    const esMio = c.esMio;
                    const claseMio = esMio ? "chat-right" : "chat-left";
                    const ruta = c.rutaArchivo || c.RutaArchivo;
                    const ext = (c.extension || c.Extension || "").toLowerCase();
                    const nombreFoto = c.fotoPerfil || c.FotoPerfil;

                    // Foto de perfil sin timestamp para optimizar caché
                    const fotoUrl = (nombreFoto && nombreFoto.trim() !== "")
                        ? `/uploads/perfiles/${nombreFoto}`
                        : `/sbadmin2/img/undraw_profile.svg`;

                    // Construcción del mensaje con el mismo estilo que Tickets y Reclamos
                    html += `
                        <div class="d-flex ${esMio ? 'flex-row-reverse' : ''} mb-3">
                            <img src="${fotoUrl}"
                                 class="rounded-circle border shadow-sm"
                                 style="width: 35px; height: 35px; object-fit: cover; flex-shrink: 0; ${esMio ? 'margin-left: 10px;' : 'margin-right: 10px;'}"
                                 onerror="this.src='/sbadmin2/img/undraw_profile.svg'">

                            <div class="chat-message ${claseMio}" style="max-width: 80%;">
                                <span class="chat-user">${c.nombreUsuario || "Usuario"}</span>
                                <div>${c.mensaje || ""}</div>`;

                    if (ruta) {
                        if (ext.match(/(mp4|webm|ogg)$/i)) {
                            html += `
                                <div class="mt-2">
                                    <a href="${ruta}" target="_blank" class="btn btn-sm btn-outline-danger shadow-sm d-inline-flex align-items-center">
                                        <i class="fas fa-play-circle fa-2x me-2"></i>
                                        <div class="text-start">
                                            <small class="d-block fw-bold">Ver Video</small>
                                            <span style="font-size: 0.65rem;">Haga clic para reproducir</span>
                                        </div>
                                    </a>
                                </div>`;
                        } else if (ext.match(/(jpg|jpeg|png|gif)$/i)) {
                            html += `<a href="${ruta}" target="_blank"><img src="${ruta}" class="img-fluid rounded mt-2 border shadow-sm" style="max-height:150px"></a>`;
                        } else {
                            html += `<div class="mt-2"><a href="${ruta}" target="_blank" class="btn btn-sm btn-light border small"><i class="fas fa-file"></i> Ver Adjunto</a></div>`;
                        }
                    }

                    html += `       <span class="chat-time">${c.fecha || ""}</span>
                            </div>
                        </div>`;
                });

                // Inyectamos el contenido (esto reemplaza el spinner automáticamente)
                $("#chatBox").html(html);

                // 3. Scroll inteligente: Solo baja si llegaron mensajes nuevos
                if (data.length > ultimaCantidadComentarios) {
                    $("#chatBox").scrollTop($("#chatBox")[0].scrollHeight);
                }

                ultimaCantidadComentarios = data.length;

                if (typeof marcarComoLeido === "function") marcarComoLeido();
            });
        }

        function cargarComentarios() {
            if (!Seleccionado) return;

            // Reseteamos el contador al cargar una anulación distinta
            ultimaCantidadComentarios = 0;

            $("#chatBox").html('<div class="text-center p-5"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
            actualizarChatSilencioso();
        }
        function enviarComentario() {
            const msg = $("#txtMensajeChat").val().trim();
            const file = $("#fArchivoChat")[0].files[0];
            if (!msg && !file) return;


            let formData = new FormData();
            formData.append("idAnulacion", Seleccionado.IdAnulacion || Seleccionado.idAnulacion);
            formData.append("mensaje", msg);
            if (file) formData.append("archivo", file);

            $.ajax({
                url: '@Url.Action("GuardarComentario", "Anulaciones")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function(res) {
                    Swal.close(); // Cerramos el cargando al terminar
                    if (res.success) {
                        $("#txtMensajeChat").val("");
                        limpiarArchivoChat();
                        actualizarChatSilencioso();
                    } else {
                        Swal.fire('Error', res.mensaje || 'No se pudo enviar', 'error');
                    }
                },
                error: function() {
                    Swal.close();
                    Swal.fire('Error', 'Ocurrió un error en el servidor', 'error');
                }
            });
        }


         function monitorearMensajesNuevos() {
      
             sincronizarEstadosChatMasivo();
        }

        // --- 9. OTRAS UTILIDADES ---
        function seleccionarArchivoChat(input) {
            if (input.files.length > 0) {
                const file = input.files[0];

                // Mostramos el nombre del archivo
                $("#lblNombreArchivoChat").text(file.name);
                $("#divPreviewChat").show();

                // Si es una imagen, generamos una miniatura rápida
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        // Creamos o actualizamos un elemento <img> para la vista previa
                        if ($("#imgMiniaturaChat").length === 0) {
                            $("#divPreviewChat").prepend('<img id="imgMiniaturaChat" src="" style="max-height: 50px; margin-right: 10px; border-radius: 5px; border: 1px solid #ddd;">');
                        }
                        $("#imgMiniaturaChat").attr("src", e.target.result).show();
                    };
                    reader.readAsDataURL(file);
                } else {
                    // Si no es imagen (ej. un PDF), escondemos la miniatura si existía
                    $("#imgMiniaturaChat").hide();
                }
            }
        }
        function limpiarArchivoChat() {
            $("#fArchivoChat").val("");
            $("#divPreviewChat").hide();
            $("#imgMiniaturaChat").hide(); // Limpiamos la miniatura
        }
        function cargarAdjuntos(id) {
            $.get('@Url.Action("ObtenerAdjuntos", "Anulaciones")', { idAnulacion: id }, function(data) {
                let html = data.map(x => `<a href="${x.ruta}" target="_blank" class="list-group-item list-group-item-action small">${x.nombreOriginal}</a>`).join('');
                $("#listaAdjuntos").html(html || '<div class="p-3 text-center text-muted small">No hay archivos</div>');
            });
        }

        function abrirModalNuevo() { $("#modalNuevoTicket").modal("show"); }

        function crearTicket() {


            const anulacion = {
                idAnulacion: 0,
                IdIncidencias: parseInt($("#cboIncidencia").val()),
                IdCaja: parseInt($("#cboCaja").val()),
                IdEstado: 3
            };

            console.log("Datos a enviar:", anulacion); // Para que veas en la consola si se armó bien
            enviarDatos(anulacion, "INSERT", "#fArchivos");
        }


       function guardarCambiosTicket() {
            if (!Seleccionado) return;
            const res = $("#txtResolucion").val().trim();
            const nuevoEstadoId = (res !== "") ? 4 : 5;
            const nuevoEstadoTexto = (res !== "") ? "Cerrado" : "En Proceso"; // <--- Agregamos esto

            const Data = {
                IdAnulacion: Seleccionado.IdAnulacion || Seleccionado.idAnulacion,
                Resolucion: res,
                IdEstado: nuevoEstadoId,
                Estado: nuevoEstadoTexto, // <--- Lo incluimos en la data
                IdIncidencias: parseInt(Seleccionado.idIncidencias || Seleccionado.IdIncidencias || 0),
                IdCaja: Seleccionado.IdCaja || Seleccionado.idCaja,
                IdUsuarioAsignado: idUsuarioLogueado,
                UsuarioAsignado: nombreTecnicoLogueado // <--- Aseguramos que se mantenga el nombre
            };
           // PRUEBA EN CONSOLA: Antes de enviar, abre F12 y mira si IdIncidencias tiene valor
           console.log("Enviando este objeto:", Data);

           if (!Data.IdIncidencias || Data.IdIncidencias === 0) {
               Swal.fire("Atención", "No se pudo recuperar el ID de la incidencia. Intenta recargar la página.", "warning");
               return;
           }
            Swal.fire({
                title: '¿Guardar cambios?',
                text: (nuevoEstadoId === 4) ? "Se CERRARÁ." : "Se actualizará el progreso.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, guardar'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Guardando...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    let formData = new FormData();
                    formData.append("Accion", "UPDATE");
                    for (let key in Data) {
                        formData.append("anulacion." + key, Data[key]);
                    }

                    $.ajax({
                        url: '@Url.Action("GuardarAnulacion", "Anulaciones")',
                        type: "POST",
                        data: formData,
                        contentType: false,
                        processData: false,
                        success: function (response) {
                            if (response.success) {
                                Swal.fire('Éxito', 'Actualizado', 'success').then(() => {
                                    refrescarTablaTickets();
                                    // PASO CLAVE: Pasamos el objeto con el NUEVO estado para que verDetalle lo oculte
                                    if (nuevoEstadoId === 4) {
                                        bloquearChatVisualmente();
                                    }
                                    verDetalle(ticketData);
                                });
                            } else {
                                Swal.fire('Error', response.mensaje || 'No se pudo actualizar', 'error');
                            }
                        }
                    });
                }
            });
        }

       function enviarDatos(obj, accion, fileInputId = null) {
            let formData = new FormData();
            formData.append("Accion", accion);
            for (let key in obj) { formData.append("anulacion." + key, obj[key]); }
            if (fileInputId) {
                let files = $(fileInputId)[0].files;
                for (let i = 0; i < files.length; i++) { formData.append("archivos", files[i]); }
            }
            $.ajax({
                url: '@Url.Action("GuardarAnulacion", "Anulaciones")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    Swal.close();
                    if (res.success) {
                        $("#modalNuevoTicket").modal("hide");
                        Swal.fire('Listo', 'Operación exitosa', 'success').then(() => {
                            refrescarTablaTickets();
                            // Limpiamos la vista de detalle para obligar a seleccionar de nuevo
                            $("#seccionDetalle").hide();
                            $("#detalleVacio").show();
                            Seleccionado = null;
                        });
                    } else {
                        Swal.fire('Error', res.mensaje || 'No se pudo guardar', 'error');
                    }
                }
            });
        }


        // Escuchar el evento de pegado en toda la página
        document.addEventListener('paste', function (e) {
            // Solo si hay un ticket abierto
            if (!Seleccionado) return;

            const items = (e.clipboardData || e.originalEvent.clipboardData).items;

            for (let i = 0; i < items.length; i++) {
                if (items[i].kind === 'file') {
                    const blob = items[i].getAsFile();

                    // Creamos un contenedor de archivos para el input file
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(blob);

                    // Lo asignamos al input real
                    const inputArchivo = document.getElementById('fArchivoChat');
                    inputArchivo.files = dataTransfer.files;

                    // Cambiamos a la pestaña de chat si no está activa para que el usuario vea que se cargó
                    const tabChat = document.querySelector('#ticketTabs button[data-bs-target="#chatTab"]');
                    if (tabChat) {
                        bootstrap.Tab.getInstance(tabChat)?.show() || new bootstrap.Tab(tabChat).show();
                    }

                    // Llamamos a tu función de vista previa
                    seleccionarArchivoChat(inputArchivo);
                }
            }
        });

        function bloquearChatVisualmente() {
            $("#txtMensajeChat").prop("disabled", true)
                .val("")
                .attr("placeholder", "Caso cerrado - No se admiten más mensajes");
            $(".btn-primary[onclick='enviarComentario()']").prop("disabled", true);
            $("#fArchivoChat").prop("disabled", true);
            $(".fa-paper-plane").closest("button").addClass("btn-secondary").removeClass("bg-primary");

            // Opcional: Ocultar el botón de guardar si ya está cerrado
            $("#btnGuardarTicket").hide();
        }
    </script>
}

