@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();

    var nombreUsuario = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario");
    var permisosString = HttpContextAccessor.HttpContext.Session.GetString("Permisos");

    var permisos = string.IsNullOrEmpty(permisosString)
        ? new List<string>()
        : permisosString.Split(',').Select(p => p.Trim()).ToList();

    bool Tiene(string permiso) => permisos.Contains(permiso);

    bool IsActive(string action, string controller = "home")
        => currentAction == action.ToLower() &&
           currentController == controller.ToLower();

    bool IsMenuOpen(params string[] actions)
        => actions.Any(a => a.ToLower() == currentAction);

    // Recuperamos datos de sesión

    // Recuperamos los datos tal cual se guardan en el Login
    // Nota: Como en el Login guardas Nombre + Apellido en "NombreUsuario", 
    // solo necesitamos esa variable.
    // Extraemos directamente de la sesión
    // En el _Layout.cshtml, intenta cambiar esto:
    var nombreSession = Context.Session.GetString("NombreUsuario");
    var fotoSession = Context.Session.GetString("FotoPerfil");

    // Si la sesión es nula, intentamos forzar un valor para ver si el problema es la sesión o el string
    string nombreFinal = !string.IsNullOrEmpty(nombreSession) ? nombreSession : "Usuario No Identificado";

    string rutaFoto = !string.IsNullOrEmpty(fotoSession)
        ? Url.Content("~/uploads/perfiles/" + fotoSession)
        : Url.Content("~/sbadmin2/img/undraw_profile.svg");
}

