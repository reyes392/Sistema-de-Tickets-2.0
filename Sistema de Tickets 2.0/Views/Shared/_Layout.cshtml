    <script>
    let cargaInicial = true;
        /*   const audioUrl = "https://fonts.gstatic.com/s/i/productnotifications/v1/notification.mp3";*/
        const audioUrl = "https://actions.google.com/sounds/v1/alarms/beep_short.ogg";
    let notificationSound = new Audio(audioUrl);
    notificationSound.preload = "auto";

    // Función principal para sonar
    function tocarTimbre() {
        let playPromise = notificationSound.play();
        if (playPromise !== undefined) {
            playPromise.catch(error => {
                console.warn("Audio bloqueado. Esperando interacción del usuario.");
            });
        }
    }

    function revisarNotificaciones() {
        $.ajax({
            url: '@Url.Action("VerificarNotificaciones", "Home")',
            type: "GET",
            dataType: "json",
            success: function (res) {
                console.log("Actividad detectada:", res.total);

                if (cargaInicial) {
                    cargaInicial = false;
                    return;
                }

                if (res.total > 0) {
                    tocarTimbre();
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'info',
                        title: '¡Nueva Actividad!',
                        text: 'Hay cambios recientes en el sistema.',
                        showConfirmButton: false,
                        timer: 10000
                    });
                }
            }
        });
    }



    $(document).ready(function () {
        // --- DESBLOQUEADOR AUTOMÁTICO ---
        // Cualquier clic en la página (menú, tablas, fondo) activará el audio
        const desbloquearAudio = function () {
            notificationSound.play().then(() => {
                // Si entra aquí, ya tenemos permiso. Paramos el audio inmediatamente.
                notificationSound.pause();
                notificationSound.currentTime = 0;
                console.log("🔊 Audio desbloqueado por interacción.");

                // Quitamos los listeners para no gastar recursos
                document.removeEventListener('click', desbloquearAudio);
                document.removeEventListener('keydown', desbloquearAudio);
            }).catch(e => {
                console.log("Navegador aún no permite audio...");
            });
        };

        // Escuchamos clics o teclas (para cuando el usuario navega)
        document.addEventListener('click', desbloquearAudio);
        document.addEventListener('keydown', desbloquearAudio);

        // Iniciar el ciclo de revisión
        setInterval(revisarNotificaciones, 20000);
    });
    </script>


