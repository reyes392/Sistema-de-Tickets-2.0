@model List<Capa_Entidad.ReclamosBodega.E_ReclamosBodega>
@using Capa_Entidad.ReclamosBodega
@{
    ViewData["Title"] = "Reclamos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Estilos para el Chat */
    #chatBox {
        height: 350px;
        overflow-y: auto;
        background-color: #f8f9fa;
        display: flex;
        flex-direction: column;
        padding: 15px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        gap: 12px;
    }

    .chat-message {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 10px;
        position: relative;
        font-size: 0.9rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .chat-left {
        align-self: flex-start;
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        color: #333;
    }

    .chat-right {
        align-self: flex-end;
        background-color: #0d6efd;
        color: white;
    }

    .chat-time {
        font-size: 0.65rem;
        display: block;
        margin-top: 4px;
        opacity: 0.7;
    }

    .chat-user {
        font-size: 0.7rem;
        font-weight: bold;
        display: block;
        margin-bottom: 2px;
    }

    .notif-badge {
        font-size: 0.6rem;
        padding: 4px 6px;
        margin-left: 5px;
        animation: pulse 2s infinite;
    }
    /* Contenedor del mensaje que permite alinear foto y texto */
    .chat-message-container {
        display: flex;
        align-items: flex-end;
        margin-bottom: 15px;
    }

    /* Foto de perfil pequeña en el chat */
    .chat-avatar {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 8px;
        border: 1px solid #ddd;
        flex-shrink: 0; /* Evita que la foto se aplaste */
    }

    /* Ajuste para que el mensaje del remitente (derecha) se alinee al final */
    .chat-right-container {
        flex-direction: row-reverse;
        text-align: right;
    }
    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>

<div class="container-fluid mt-3">
    <div class="row">
        @* --- LISTADO DE RECLAMOS --- *@
        <div class="col-md-6 border-end">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-ticket-alt"></i> Listado de Reclamos</h2>
                <button class="btn btn-primary shadow-sm" onclick="abrirModalNuevo()">
                    <i class="fas fa-plus-circle"></i> Nuevo Reclamo
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover shadow-sm border" id="tblReclamos">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Solicitante</th>
                            <th>Incidencia</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr id="row-@t.IdReclamo">
                                <td>
                                    <span class="fw-bold">@t.IdReclamo</span>
                                    <span id="notif-@t.IdReclamo" class="badge rounded-pill bg-danger d-none notif-badge">
                                        <i class="fas fa-comment"></i>
                                    </span>
                                </td>
                                <td>@t.UsuarioSolicitador</td>
                                <td>@t.TipoIncidenciaReclamo</td>
                                <td>@t.Registro</td>
                                <td>
                                    <span class="badge @(t.Estado == "Pendiente" ? "bg-warning text-dark" : (t.Estado == "Cerrado" ? "bg-success" : "bg-info"))">
                                        @t.Estado
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary btn-ver" data-info='@Json.Serialize(t)'>
                                        <i class="fas fa-eye"></i> Ver
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* --- DETALLE DEL RECLAMO --- *@
        <div class="col-md-6 bg-light p-4" id="seccionDetalle" style="display:none; min-height: 85vh;">
            <ul class="nav nav-tabs" id="ticketTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#info" type="button">
                        <i class="fas fa-info-circle"></i> Gestión
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-bold" id="tabChat" data-bs-toggle="tab" data-bs-target="#chatTab" type="button" onclick="marcarComoLeido(); cargarComentarios(); iniciarRefrescoChat();">
                        <i class="fas fa-comments"></i> Chat / Notas
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#adjuntosTab" type="button">
                        <i class="fas fa-paperclip"></i> Adjuntos
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-4 bg-white shadow-sm">
                @* Pestaña Información *@
                <div class="tab-pane fade show active" id="info">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-primary m-0">Reclamo #<span id="lblIdReclamo"></span></h5>
                        <span id="badgeEstado" class="badge p-2"></span>
                    </div>

                    <div class="row g-2 mb-4 border-bottom pb-3">
                        <div class="col-6 small"><strong>Solicitante:</strong> <span id="txtSolicitante" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Incidencia:</strong> <span id="txtIncidencia" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong># Requisa:</strong> <span id="txtNrequisa" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Fecha de Requisa:</strong> <span id="txtFechaRequisa" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Asignado a :</strong> <span id="txtAsignado" class="d-block text-muted"></span></div>

                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small">Descripción del Problema:</label>
                        <textarea id="txtDetalleProblema" class="form-control bg-light" rows="3" readonly></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small text-success">Resolución Técnica:</label>
                        <textarea id="txtResolucion" class="form-control border-success" rows="4"></textarea>
                    </div>

                    <div class="d-flex justify-content-between mb-4 small text-muted">
                        <span>Registro: <b id="lblRegistro"></b></span>
                        <span>Modif: <b id="lblModif"></b></span>
                    </div>

                    <div id="contenedorBotonGuardar">
                        <button id="btnGuardarReclamo" class="btn btn-success w-100" onclick="guardarCambiosReclamos()">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                </div>

                @* Pestaña Chat *@
                <div class="tab-pane fade" id="chatTab">
                    <div id="chatBox"></div>
                    <div id="divPreviewChat" class="mt-2" style="display:none;">
                        <span class="badge bg-info text-dark">
                            <i class="fas fa-paperclip"></i> <span id="lblNombreArchivoChat"></span>
                            <i class="fas fa-times ms-2" style="cursor:pointer" onclick="limpiarArchivoChat()"></i>
                        </span>
                    </div>
                    <div class="input-group mt-3" id="contenedorEscrituraChat">
                        <input type="file" id="fArchivoChat" style="display:none" onchange="seleccionarArchivoChat(this)" />
                        <button class="btn btn-outline-secondary" type="button" onclick="$('#fArchivoChat').click()">
                            <i class="fas fa-paperclip"></i>
                        </button>
                        <input type="text" id="txtMensajeChat" class="form-control" placeholder="Escribe un comentario..." onkeypress="if(event.keyCode==13) enviarComentario()">
                        <button class="btn btn-primary" type="button" onclick="enviarComentario()">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>

                @* Pestaña Adjuntos *@
                <div class="tab-pane fade" id="adjuntosTab">
                    <h6 class="fw-bold mb-3">Archivos cargados al crear ticket:</h6>
                    <div id="listaAdjuntos" class="list-group list-group-flush border mb-3"></div>
                </div>
            </div>
        </div>

        <div class="col-md-6 d-flex align-items-center justify-content-center bg-light border" id="detalleVacio" style="min-height: 85vh;">
            <div class="text-center text-muted">
                <i class="fas fa-mouse-pointer fa-3x mb-3"></i>
                <p>Selecciona un ticket de la lista para ver el detalle</p>
            </div>
        </div>
    </div>
</div>

@* --- MODAL NUEVO Reclamo --- *@
<div class="modal fade" id="modalNuevoReclamo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-plus-circle"></i> Nuevo Reclamo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Tipo de Incidencia</label>
                    <select id="cboIncidencia" class="form-select border-primary">
                        @foreach (var item in ViewBag.Incidencias)
                        {
                            <option value="@item.IdTiposIncidenciasReclamo">@item.Descripcion</option>
                        }
                    </select>
                </div>


                @* --- agregando nuevos --- *@
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Numero de Requisa</label>
                    <input type="text" class="form-control" id="Nrequisa" autocomplete="off" maxlength="20" placeholder="ejemplo : A123456789">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Fecha de la requisa</label>
                    <input class="form-control" type="text" id="FechaRequisa" autocomplete="off" maxlength="20"  placeholder="ejemplo : 25/01/2026">
                </div>

                @* ---  --- *@
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Descripción del Problema</label>
                    <textarea id="nuevoProblema" class="form-control" rows="3" placeholder="Detalla lo que está ocurriendo..." maxlength="500"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase text-primary">
                        <i class="fas fa-paperclip"></i> Adjuntar Archivos y Videos (Opcional)
                    </label>
                    <input type="file" id="fArchivos" class="form-control" multiple
                           accept="image/*,video/mp4,video/x-m4v,video/*,.pdf,.doc,.docx,.xls,.xlsx" />
                    <div class="form-text" style="font-size: 0.75rem;">
                        Puedes subir imágenes, documentos o videos cortos (MP4).
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-muted" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary px-4" onclick="crearReclamo()">Crear Reclamo</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
       // --- FUNCIONES GLOBALES ---
        window.verImagenFull = function (url) { if (url) window.open(url, '_blank'); };

        // --- 1. VARIABLES GLOBALES Y ESTADO ---
        let reclamoSeleccionado = null;
        let chatTimer = null;
        let tituloOriginal = document.title;
        let intervaloPestaña = null;
        let ultimoIdComentarioVisto = {};
        let versionReclamoActual = "";
        let ultimaCantidadComentarios = 0;

        const idUsuarioLogueado = parseInt('@ViewBag.IdUsuarioLogueado') || 0;
        const nombreTecnicoLogueado = '@ViewBag.NombreUsuarioLogueado';
        const rolUsuarioLogueado = parseInt('@ViewBag.RolUsuario') || 0;

        $(document).ready(function () {
            $('#tblReclamos').DataTable({
                pageLength: 10,
                order: [],
                language: { url: "//cdn.datatables.net/plug-ins/1.10.24/i18n/Spanish.json" }
            });

            // --- 2. INICIALIZACIÓN MASIVA ---
            inicializarEstadosChats();

            // Obtener versión inicial
            $.get('@Url.Action("ObtenerVersionReclamos", "ReclamosBodega")', v => { versionReclamoActual = v; });

            // --- 3. TIMERS ---
            setInterval(verificarCambiosReclamo, 10000); // Cambios en tabla
            setInterval(monitorearMensajesNuevos, 6000); // Mensajes nuevos (Masivo)
        });

        // --- NUEVA FUNCIÓN: CARGA INICIAL MASIVA ---
        function inicializarEstadosChats() {
            let ids = [];
            $(".btn-ver").each(function () {
                let info = $(this).data("info");
                ids.push(info.IdReclamo || info.idReclamo);
            });

            if (ids.length === 0) return;

            // Usamos el nuevo endpoint masivo que hicimos en el controlador
            $.ajax({
                url: '@Url.Action("ObtenerEstadosChatsReclamos", "ReclamosBodega")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(ids),
                success: function (res) {
                    res.forEach(estado => {
                        const guardado = localStorage.getItem(`visto_u${idUsuarioLogueado}_r${estado.idReclamo}`);
                        const ultimoVisto = guardado ? parseInt(guardado) : 0;

                        ultimoIdComentarioVisto[estado.idReclamo] = Math.max(estado.ultimoId, ultimoVisto);

                        if (estado.ultimoId > ultimoVisto && estado.idAutor !== idUsuarioLogueado) {
                            $(`#notif-${estado.idReclamo}`).removeClass("d-none");
                        }
                    });
                }
            });
        }

        // --- 4. FUNCIÓN: DETECTAR CAMBIOS EN EL SERVIDOR ---
        function verificarCambiosReclamo() {
            $.get('@Url.Action("ObtenerVersionReclamos", "ReclamosBodega")', function (nuevaVersion) {
                if (versionReclamoActual !== "" && nuevaVersion !== versionReclamoActual) {
                    versionReclamoActual = nuevaVersion;
                    refrescarTablaReclamos();

                    if (!intervaloPestaña) {
                        intervaloPestaña = setInterval(() => {
                            document.title = (document.title === tituloOriginal) ? "✨ ACTUALIZACIÓN ✨" : tituloOriginal;
                        }, 1000);
                    }
                }
            });
        }

     
        function refrescarTablaReclamos() {
            $.get(window.location.href, function (data) {
                const nuevoContenido = $(data).find("#tblReclamos tbody").html();
                $("#tblReclamos tbody").html(nuevoContenido);

                // IMPORTANTE: Volver a ejecutar la lógica de badges
                setTimeout(() => {
                    inicializarEstadosChats();
                }, 100);
            });
        }

        // --- 5. MONITOREO MASIVO DE MENSAJES (OPTIMIZADO) ---
        function monitorearMensajesNuevos() {
            let ids = [];
            $(".btn-ver").each(function() {
                ids.push($(this).data("info").IdReclamo || $(this).data("info").idReclamo);
            });

            if (ids.length === 0) return;

            $.ajax({
                url: '@Url.Action("ObtenerEstadosChatsReclamos", "ReclamosBodega")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(ids),
                success: function (res) {
                    const idAbierto = reclamoSeleccionado?.IdReclamo || reclamoSeleccionado?.idReclamo;

                    res.forEach(estado => {
                        const guardado = localStorage.getItem(`visto_u${idUsuarioLogueado}_r${estado.idReclamo}`);
                        const ultimoVisto = guardado ? parseInt(guardado) : (ultimoIdComentarioVisto[estado.idReclamo] || 0);

                        if (estado.ultimoId > ultimoVisto && estado.idAutor !== idUsuarioLogueado) {
                            // Si estoy viendo este chat y la pestaña de chat está activa
                            if (idAbierto == estado.idReclamo && $("#chatTab").hasClass("active")) {
                                marcarComoLeido();
                            } else {
                                $(`#notif-${estado.idReclamo}`).removeClass("d-none");
                            }
                        } else {
                            $(`#notif-${estado.idReclamo}`).addClass("d-none");
                        }
                    });
                }
            });
        }

        // --- 6. EVENTO: VER DETALLE ---
        $(document).on("click", ".btn-ver", function () {
            let $btn = $(this);
            let info = $btn.data("info");
            const idReclamo = info.IdReclamo || info.idReclamo;

            if (intervaloPestaña) {
                clearInterval(intervaloPestaña);
                intervaloPestaña = null;
                document.title = tituloOriginal;
            }

            const idAsignadoActual = info.IdUsuarioAsignado || info.idUsuarioAsignado;

            if ((!idAsignadoActual || idAsignadoActual === 0) && (rolUsuarioLogueado === 1 || rolUsuarioLogueado === 3)) {
                $.post('@Url.Action("TomarReclamo", "ReclamosBodega")', { idReclamo: idReclamo }, function (res) {
                    if (res.success) {
                        info.IdEstado = 5;
                        info.Estado = "En Proceso";
                        info.IdUsuarioAsignado = idUsuarioLogueado;
                        $btn.data("info", info);
                        $btn.closest("tr").find(".badge").first().text("En Proceso").attr("class", "badge bg-info");
                    }
                    verDetalle(info);
                });
            } else {
                verDetalle(info);
            }
        });

        const formatearFecha = (f) => {

            if (!f) return "N/A";

            let d = new Date(f);

            return isNaN(d) ? f : d.toLocaleString();

        };
        function verDetalle(reclamo) {
            if (!reclamo) return;
            if (chatTimer) clearInterval(chatTimer);

            $("#txtResolucion").val("");
            $("#txtDetalleProblema").val("");
            $("#chatBox").html("");
            reclamoSeleccionado = reclamo;

            $("#seccionDetalle").show();
            $("#detalleVacio").hide();

            const id = reclamo.IdReclamo || reclamo.idReclamo;
            const estado = reclamo.Estado || reclamo.estado;

            // Llenado de UI
            $("#lblIdReclamo").text(id);
            $("#txtSolicitante").text(reclamo.UsuarioSolicitador || reclamo.usuarioSolicitador || "N/A");
            $("#txtIncidencia").text(reclamo.TipoIncidenciaReclamo || reclamo.tipoIncidenciaReclamo || "N/A");
            $("#txtNrequisa").text(reclamo.Nrequisa || reclamo.nrequisa || "N/A");
            $("#txtDetalleProblema").val(reclamo.Problema || reclamo.problema || "N/A");
            $("#txtResolucion").val(reclamo.Resolucion || reclamo.resolucion || "");
            $("#txtFechaRequisa").text(reclamo.fechaRequisa || reclamo.FechaRequisa || "N/A");
            $("#txtAsignado").text(reclamo.usuarioAsignado || reclamo.UsuarioAsignado || "N/A");
            $("#lblRegistro").text(formatearFecha(reclamo.registro || reclamo.Registro));

            $("#lblModif").text(formatearFecha(reclamo.modificacion || reclamo.Modificacion));



            // IMPORTANTE: Usar .val() para que el textarea se refresque correctamente

            $("#txtDetalleProblema").val(reclamo.problema || reclamo.Problema || "N/A");

            $("#txtResolucion").val(reclamo.resolucion || reclamo.Resolucion || "");
            // Bloqueo si está cerrado
            if (estado === "Cerrado") {
                $("#txtMensajeChat, #fArchivoChat, .btn-primary[onclick='enviarComentario()']").prop("disabled", true);
                $("#txtMensajeChat").attr("placeholder", "Reclamo cerrado");
            } else {
                $("#txtMensajeChat, #fArchivoChat, .btn-primary[onclick='enviarComentario()']").prop("disabled", false);
                $("#txtMensajeChat").attr("placeholder", "Escribe un comentario...");
            }
            // Lógica de Seguridad para edición
            let puedeEditar = (estado !== "Cerrado" && (rolUsuarioLogueado === 1 || idAsignado === idUsuarioLogueado));
            if (puedeEditar) {
                $("#btnGuardarReclamo").show();
                $("#txtResolucion, #txtDetalleProblema").prop("readonly", false).removeClass("bg-light");
            } else {
                $("#btnGuardarReclamo").hide();
                $("#txtResolucion, #txtDetalleProblema").prop("readonly", true).addClass("bg-light");
            }
            actualizarChatSilencioso();
            marcarComoLeido();
            cargarAdjuntos(id);
            iniciarRefrescoChat();
        }

        function marcarComoLeido() {
            if (!reclamoSeleccionado) return;
            const id = reclamoSeleccionado.IdReclamo || reclamoSeleccionado.idReclamo;
            $(`#notif-${id}`).addClass("d-none");

            $.get('@Url.Action("ObtenerUltimoComentarioId", "ReclamosBodega")', { idReclamo: id }, function (res) {
                if(res.ultimoId >= 0) {
                    ultimoIdComentarioVisto[id] = res.ultimoId;
                    localStorage.setItem(`visto_u${idUsuarioLogueado}_r${id}`, res.ultimoId);
                }
            });
        }

        function iniciarRefrescoChat() {
            chatTimer = setInterval(() => {
                if ($("#chatTab").hasClass("active")) actualizarChatSilencioso();
            }, 3000);
        }

        function actualizarChatSilencioso() {
            if (!reclamoSeleccionado) return;
            const id = reclamoSeleccionado.IdReclamo || reclamoSeleccionado.idReclamo;

            $.get('@Url.Action("ObtenerComentarios", "ReclamosBodega")', { idReclamo: id }, function (data) {
                if (data.length === ultimaCantidadComentarios) return;

                let html = "";
                data.forEach(c => {
                    const esMio = c.esMio;
                    const fotoUrl = (c.fotoPerfil) ? `/uploads/perfiles/${c.fotoPerfil}` : `/sbadmin2/img/undraw_profile.svg`;

                    html += `
                        <div class="d-flex ${esMio ? 'flex-row-reverse' : ''} mb-3">
                            <img src="${fotoUrl}" class="rounded-circle border" style="width: 38px; height: 38px; object-fit: cover;">
                            <div class="chat-message ${esMio ? 'chat-right' : 'chat-left'} ml-2 mr-2" style="max-width: 80%;">
                                <span class="chat-user">${c.nombreUsuario}</span>
                                <div class="chat-text">${c.mensaje || ""}</div>
                                ${c.rutaArchivo ? `<div class="mt-2"><a href="${c.rutaArchivo}" target="_blank" class="btn btn-sm btn-light border">Ver Adjunto</a></div>` : ''}
                                <span class="chat-time">${c.fecha}</span>
                            </div>
                        </div>`;
                });

                $("#chatBox").html(html || '<div class="text-center text-muted small mt-4">No hay mensajes.</div>');
                if (data.length > ultimaCantidadComentarios) {
                    $("#chatBox").scrollTop($("#chatBox")[0].scrollHeight);
                }
                ultimaCantidadComentarios = data.length;
                marcarComoLeido();
            });
        }

        function cargarComentarios() {
            if (!reclamoSeleccionado) return;

            // Al cargar un ticket nuevo, reseteamos el conteo para que el chat se dibuje sí o sí
            ultimaCantidadComentarios = 0;

            $("#chatBox").html('<div class="text-center p-5"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
            actualizarChatSilencioso();
        }

        function enviarComentario() {
            const msg = $("#txtMensajeChat").val().trim();
            const file = $("#fArchivoChat")[0].files[0];
            if (!msg && !file) return;


            let formData = new FormData();
            formData.append("idReclamo", reclamoSeleccionado.IdReclamo || reclamoSeleccionado.idReclamo);
            formData.append("mensaje", msg);
            if (file) formData.append("archivo", file);

            $.ajax({
                url: '@Url.Action("GuardarComentario", "ReclamosBodega")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function(res) {
                    Swal.close(); // Cerramos el cargando al terminar
                    if (res.success) {
                        $("#txtMensajeChat").val("");
                        limpiarArchivoChat();
                        actualizarChatSilencioso();
                        marcarComoLeido(); // <--- Agrega esto aquí
                    } else {
                        Swal.fire('Error', res.mensaje || 'No se pudo enviar', 'error');
                    }
                },
                error: function() {
                    Swal.close();
                    Swal.fire('Error', 'Ocurrió un error en el servidor', 'error');
                }
            });
        }


        // --- 9. OTRAS UTILIDADES ---

        function seleccionarArchivoChat(input) {
            if (input.files.length > 0) {
                const file = input.files[0];
                $("#lblNombreArchivoChat").text(file.name);
                $("#divPreviewChat").show();

                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        // Diseño exacto: Contenedor con botón X rojo
                        let previewHtml = `
                    <div id="containerMiniaturaChat" style="position: relative; display: inline-block; margin-bottom: 8px;">
                        <img id="imgMiniaturaChat" src="${e.target.result}"
                             style="max-height: 60px; border-radius: 5px; border: 2px solid #3b82f6; display: block;">
                        <span onclick="limpiarArchivoChat()"
                              style="position: absolute; top: -8px; right: -8px; background: #ef4444; color: white;
                                     border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center;
                                     justify-content: center; font-size: 11px; cursor: pointer; border: 2px solid white; z-index: 10;">
                            <i class="fas fa-times"></i>
                        </span>
                    </div>`;

                        if ($("#containerMiniaturaChat").length > 0) {
                            $("#containerMiniaturaChat").replaceWith(previewHtml);
                        } else {
                            $("#divPreviewChat").prepend(previewHtml);
                        }
                    };
                    reader.readAsDataURL(file);
                } else {
                    // Si no es imagen, solo quitamos la miniatura previa pero mostramos el nombre
                    $("#containerMiniaturaChat").remove();
                }
            }
        }

        function limpiarArchivoChat() {
            $("#fArchivoChat").val("");           // Limpia el input
            $("#containerMiniaturaChat").remove(); // Quita la foto con la X
            $("#divPreviewChat").hide();          // Esconde el contenedor
            $("#lblNombreArchivoChat").text("");  // Limpia el nombre del archivo
            $("#imgMiniaturaChat").hide(); // Limpiamos la miniatura
        }

        function cargarAdjuntos(id) {
            $.get('@Url.Action("ObtenerAdjuntos", "ReclamosBodega")', { idReclamo: id }, function(data) {
                let html = data.map(x => `<a href="${x.ruta}" target="_blank" class="list-group-item list-group-item-action small">${x.nombreOriginal}</a>`).join('');
                $("#listaAdjuntos").html(html || '<div class="p-3 text-center text-muted small">No hay archivos</div>');
            });
        }

        function abrirModalNuevo() { $("#modalNuevoReclamo").modal("show"); }

        function crearReclamo() {
            // Validar que el problema no esté vacío antes de enviar
            if ($("#nuevoProblema").val().trim() === "") {
                Swal.fire('Atención', 'Por favor describe el problema', 'warning');
                return;
            }

            const reclamo = {
                IdReclamo: 0,
                IdTipoIncidencia: parseInt($("#cboIncidencia").val()),
                // Corregidos para que coincidan con los id del HTML:
                Nrequisa: $("#Nrequisa").val(),
                FechaRequisa: $("#FechaRequisa").val(),
                Problema: $("#nuevoProblema").val(),
                IdEstado: 3
            };

            console.log("Datos a enviar:", reclamo); // Para que veas en la consola si se armó bien
            enviarDatos(reclamo, "INSERT", "#fArchivos");
        }

        function guardarCambiosReclamos() {
            if (!reclamoSeleccionado) return;

            const res = $("#txtResolucion").val().trim();
            const nuevoEstadoId = (res !== "") ? 4 : 5;

            // Obtenemos el ID correctamente (manejando mayúsculas/minúsculas del JSON)
            const idActual = reclamoSeleccionado.IdReclamo || reclamoSeleccionado.idReclamo;

            const reclamoData = {
                IdReclamo: idActual,
                // Agregamos estos campos aunque no se editen, para que el SP no falle por falta de parámetros
                Nrequisa: reclamoSeleccionado.Nrequisa || reclamoSeleccionado.nrequisa,
                FechaRequisa: reclamoSeleccionado.FechaRequisa || reclamoSeleccionado.fechaRequisa,
                IdTipoIncidencia: reclamoSeleccionado.IdTipoIncidencia || reclamoSeleccionado.idTipoIncidencia || 0,

                Problema: $("#txtDetalleProblema").val().trim(),
                Resolucion: res,
                IdEstado: nuevoEstadoId,
                IdUsuarioAsignado: idUsuarioLogueado
            };

            Swal.fire({
                title: '¿Guardar cambios?',
                text: (nuevoEstadoId === 4) ? "El reclamo se CERRARÁ." : "Se actualizará el progreso.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, guardar'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Guardando...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    let formData = new FormData();
                    formData.append("Accion", "UPDATE");
                    // Por esto:
                    for (let key in reclamoData) {
                        formData.append("reclamos." + key, reclamoData[key]);
                    }

                    $.ajax({
                        url: '@Url.Action("GuardarReclamo", "ReclamosBodega")',
                        type: "POST",
                        data: formData,
                        contentType: false,
                        processData: false,
                        success: function (response) {
                            if (response.success) {
                                Swal.fire('Éxito', 'reclamo actualizado', 'success').then(() => {
                                    refrescarTablaReclamos();
                                    if (nuevoEstadoId === 4) {
                                        bloquearChatVisualmente();
                                    }
                                    // PASO CLAVE: Pasamos el objeto con el NUEVO estado para que verDetalle lo oculte
                                    verDetalle(reclamoData);
                                });
                            } else {
                                Swal.fire('Error', response.mensaje || 'No se pudo actualizar', 'error');
                            }
                        }
                    });
                }
            });
        }

       function enviarDatos(obj, accion, fileInputId = null) {
            let formData = new FormData();
            formData.append("Accion", accion);
            for (let key in obj) { formData.append("reclamos." + key, obj[key]); }
            if (fileInputId) {
                let files = $(fileInputId)[0].files;
                for (let i = 0; i < files.length; i++) { formData.append("archivos", files[i]); }
            }
            $.ajax({
                url: '@Url.Action("GuardarReclamo", "ReclamosBodega")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    Swal.close();
                    if (res.success) {
                        $("#modalNuevoReclamo").modal("hide");
                        Swal.fire('Listo', 'Operación exitosa', 'success').then(() => {
                            refrescarTablaReclamos();
                            // Limpiamos la vista de detalle para obligar a seleccionar de nuevo
                            $("#seccionDetalle").hide();
                            $("#detalleVacio").show();
                            reclamoSeleccionado = null;
                        });
                    } else {
                        Swal.fire('Error', res.mensaje || 'No se pudo guardar', 'error');
                    }
                }
            });
        }


        // Escuchar el evento de pegado en toda la página
        document.addEventListener('paste', function (e) {
            // Solo si hay un ticket abierto
            if (!reclamoSeleccionado) return;

            const items = (e.clipboardData || e.originalEvent.clipboardData).items;

            for (let i = 0; i < items.length; i++) {
                if (items[i].kind === 'file') {
                    const blob = items[i].getAsFile();

                    // Creamos un contenedor de archivos para el input file
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(blob);

                    // Lo asignamos al input real
                    const inputArchivo = document.getElementById('fArchivoChat');
                    inputArchivo.files = dataTransfer.files;

                    // Cambiamos a la pestaña de chat si no está activa para que el usuario vea que se cargó
                    const tabChat = document.querySelector('#ticketTabs button[data-bs-target="#chatTab"]');
                    if (tabChat) {
                        bootstrap.Tab.getInstance(tabChat)?.show() || new bootstrap.Tab(tabChat).show();
                    }

                    // Llamamos a tu función de vista previa
                    seleccionarArchivoChat(inputArchivo);
                }
            }
        });
        function bloquearChatVisualmente() {
            $("#txtMensajeChat").prop("disabled", true)
                .val("")
                .attr("placeholder", "Caso cerrado - No se admiten más mensajes");
            $(".btn-primary[onclick='enviarComentario()']").prop("disabled", true);
            $("#fArchivoChat").prop("disabled", true);
            $(".fa-paper-plane").closest("button").addClass("btn-secondary").removeClass("bg-primary");

            // Opcional: Ocultar el botón de guardar si ya está cerrado
            $("#btnGuardarReclamo").hide();
        }
    </script>
}

