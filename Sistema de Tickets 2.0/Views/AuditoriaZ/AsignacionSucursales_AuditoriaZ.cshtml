@model List<Capa_Entidad.Auditoria_Z.E_Asignacion_Z>
@using Capa_Entidad.Auditoria_Z
@{
    ViewData["Title"] = "AsignacionSucursales_AuditoriaZ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-primary text-white">
        <h6 class="m-0 font-weight-bold">Configuración de Asignaciones (Técnico - Sucursales)</h6>
        <button class="btn btn-light btn-sm" onclick="abrirModal()">
            <i class="fas fa-plus"></i> Nueva Asignación
        </button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="tblAsignaciones" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 80px">ID Técnico</th>
                        <th>Técnico Encargado</th>
                        <th style="width: 100px" class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAsignacion" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Configurar Relación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formAsignacion">
                    <div class="mb-4">
                        <label class="form-label font-weight-bold">1. Seleccione Técnico Encargado:</label>
                        <select class="form-select select2" id="cboTecnico" required style="width:100%">
                            <option value="">-- Seleccione Técnico --</option>
                            @foreach (var item in ViewBag.Operador)
                            {
                                <option value="@item.IdUsuario">@item.Nombres @item.Apellidos</option>
                            }
                        </select>
                    </div>
                    <hr />
                    <div class="mb-2">
                        <label class="form-label font-weight-bold mb-0">2. Marque las Sucursales (Usuarios Solicitantes):</label>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover w-100" id="tblSolicitantesModal">
                            <thead class="bg-light">
                                <tr>
                                    <th style="width: 40px" class="text-center">
                                        <input type="checkbox" id="checkAll" class="form-check-input">
                                    </th>
                                    <th>Nombre de la Sucursal / Usuario</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.Solicitantes)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input chk-solicitante" value="@item.IdUsuario">
                                        </td>
                                        <td>@item.Nombres @item.Apellidos</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-2 text-end">
                        <small class="text-primary fw-bold" id="countSelected">0 seleccionados</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarAsignacion()">Guardar Cambios</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVerDetalles" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-list me-2"></i>Detalle de Asignaciones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h6 id="txtNombreTecnicoDetalle" class="fw-bold text-primary mb-3"></h6>
                <ul class="list-group shadow-sm" id="listaSucursales">
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let tablaSolicitantes;

        $(document).ready(function () {
            // Inicializar tabla principal
            $('#tblAsignaciones').DataTable({
                language: { url: "https://cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json" },
                columnDefs: [{ className: "text-center", targets: [0, 2] }]
            });

            // Inicializar tabla del modal con scroll
            tablaSolicitantes = $('#tblSolicitantesModal').DataTable({
                "paging": false,
                "scrollY": "350px",
                "scrollCollapse": true,
                "language": { url: "https://cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json" },
                "columnDefs": [{ "orderable": false, "targets": 0 }]
            });

            listarAsignaciones();
        });

        // Eventos de Modal e Inputs
        $('#modalAsignacion').on('shown.bs.modal', function () {
            $('#cboTecnico').select2({ dropdownParent: $('#modalAsignacion'), width: '100%' });
            tablaSolicitantes.columns.adjust().draw();
        });

        $(document).on("change", "#checkAll", function() {
            $(".chk-solicitante").prop('checked', $(this).is(':checked'));
            actualizarContador();
        });

        $(document).on("change", ".chk-solicitante", function() {
            actualizarContador();
        });

        // Cargar Checkboxes al cambiar el Técnico en el Modal
        $(document).on("change", "#cboTecnico", function () {
            const idTecnico = $(this).val();
            $(".chk-solicitante").prop('checked', false);
            if (idTecnico) {
                $.get('@Url.Action("ObtenerAsignadosPorTecnico", "AuditoriaZ")', { idTecnico: idTecnico }, function (res) {
                    if (res.success && res.ids) {
                        res.ids.forEach(id => {
                            $(`.chk-solicitante[value="${id}"]`).prop('checked', true);
                        });
                        actualizarContador();
                    }
                });
            }
        });

        function listarAsignaciones() {
            $.get('@Url.Action("ListarAgrupado", "AuditoriaZ")', function (data) {
                let tabla = $('#tblAsignaciones').DataTable();
                tabla.clear();
                data.forEach(item => {
                    tabla.row.add([
                        item.idTecnico,
                        `<a href="javascript:void(0)" class="fw-bold text-primary" onclick="verDetalles(${item.idTecnico}, '${item.nombreTecnico}')">
                            <i class="fas fa-search-plus me-2"></i>${item.nombreTecnico}
                         </a>`,
                        `<button class="btn btn-primary btn-sm" onclick="editarAsignacion(${item.idTecnico})">
                            <i class="fas fa-edit"></i> Editar
                         </button>`
                    ]);
                });
                tabla.draw();
            });
        }

        function verDetalles(id, nombre) {
            $("#txtNombreTecnicoDetalle").text(nombre);
            $("#listaSucursales").html('<li class="list-group-item text-center">Cargando...</li>');
            $("#modalVerDetalles").modal("show");

            $.get('@Url.Action("ObtenerDetalleSucursales", "AuditoriaZ")', { idTecnico: id }, function (res) {
                let html = "";
                if (res.length > 0) {
                    res.forEach(d => {
                        html += `
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-store-alt me-2 text-secondary"></i>${d.sucursal}</span>
                            <button class="btn btn-sm text-danger border-0" onclick="eliminarIndividual(${d.idAsignacion})">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </li>`;
                    });
                } else {
                    html = '<li class="list-group-item text-muted">Sin sucursales asignadas.</li>';
                }
                $("#listaSucursales").html(html);
            });
        }

        function editarAsignacion(id) {
            limpiarTodo();
            $("#modalAsignacion").modal("show");
            // Esperamos un poco a que el modal se abra para setear el valor
            setTimeout(() => {
                $("#cboTecnico").val(id).trigger('change');
            }, 200);
        }

        function eliminarIndividual(id) {
            Swal.fire({
                title: '¿Quitar esta sucursal?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, quitar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("Eliminar", "AuditoriaZ")', { id: id }, function(res) {
                        if(res.success) {
                            $("#modalVerDetalles").modal("hide");
                            listarAsignaciones();
                            Swal.fire('Quitado', 'La sucursal ha sido removida.', 'success');
                        }
                    });
                }
            });
        }

        function guardarAsignacion() {
            const idTecnico = $("#cboTecnico").val();
            const solicitantesIds = [];
            $(".chk-solicitante:checked").each(function() {
                solicitantesIds.push(parseInt($(this).val()));
            });

            if (!idTecnico) {
                Swal.fire('Atención', 'Seleccione un técnico.', 'warning');
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarMultiple", "AuditoriaZ")',
                type: "POST",
                data: { idTecnico: idTecnico, idsSolicitantes: solicitantesIds },
                traditional: true,
                success: function (res) {
                    if (res.success) {
                        $("#modalAsignacion").modal("hide");
                        Swal.fire('Éxito', res.mensaje, 'success');
                        listarAsignaciones();
                    } else {
                        Swal.fire('Error', res.mensaje, 'error');
                    }
                }
            });
        }

        function actualizarContador() {
            const cant = $(".chk-solicitante:checked").length;
            $("#countSelected").text(cant + " seleccionados");
        }

        function limpiarTodo() {
            $("#formAsignacion")[0].reset();
            $("#cboTecnico").val(null).trigger('change');
            $(".chk-solicitante").prop('checked', false);
            $("#checkAll").prop('checked', false);
            actualizarContador();
        }

        function abrirModal() {
            limpiarTodo();
            $("#modalAsignacion").modal("show");
        }
    </script>
}