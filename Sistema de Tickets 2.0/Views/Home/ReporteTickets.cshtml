@model List<Capa_Entidad.Tickets.E_Tickets>
@using Capa_Entidad.Tickets

@{
    ViewData["Title"] = "ReporteTickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var lista = Model ?? new List<E_Tickets>();
}


<style>
    /* Estilos para el Chat */
    #chatBox {
        height: 350px;
        overflow-y: auto;
        background-color: #f8f9fa;
        display: flex;
        flex-direction: column;
        padding: 15px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        gap: 12px;
    }

    .chat-message {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 10px;
        position: relative;
        font-size: 0.9rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .chat-left {
        align-self: flex-start;
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        color: #333;
    }

    .chat-right {
        align-self: flex-end;
        background-color: #0d6efd;
        color: white;
    }

    .chat-time {
        font-size: 0.65rem;
        display: block;
        margin-top: 4px;
        opacity: 0.7;
    }

    .chat-user {
        font-size: 0.7rem;
        font-weight: bold;
        display: block;
        margin-bottom: 2px;
    }

    .notif-badge {
        font-size: 0.6rem;
        padding: 4px 6px;
        margin-left: 5px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }

    /* ===== TEXTO GENERAL ===== */
    body {
        color: #212529;
    }

    /* Labels y títulos */
    label, .form-label, strong {
        color: #1a1a1a;
    }

    /* Texto secundario */
    .text-muted {
        color: #6c757d !important;
    }

    /* ===== TABLAS (SOLO TEXTO) ===== */
    .table td {
        color: #2c2c2c;
    }

    .table th {
        font-weight: 600;
        color: #ffffff; /* asegura buen contraste en header oscuro */
    }

    /* ===== DETALLE DERECHO ===== */
    #seccionDetalle {
        background-color: #f4f6f9;
    }

    /* Inputs */
    .form-control {
        color: #000;
    }

    /* Textarea readonly */
    textarea[readonly] {
        background-color: #f8f9fa;
        color: #333;
    }

    /* ===== BOTONES ===== */
    .btn {
        font-weight: 500;
    }
</style>
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 mt-3">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-chart-line text-primary"></i> Reporte General de Tickets</h1>

        <div id="buttonsContainer">
            <button id="btnExportarExcel" class="btn btn-success btn-sm shadow-sm">
                <i class="fas fa-file-excel"></i> Exportar a Excel
            </button>
            <button id="btnExportarPDF" class="btn btn-danger btn-sm shadow-sm">
                <i class="fas fa-file-pdf"></i> Exportar a PDF
            </button>
        </div>
    </div>


    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped w-100" id="tblReporteMaster" width="100%" cellspacing="0">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Solicitante</th>
                            <th>Incidencia</th>
                            <th>Caja</th>
                            <th>Nivel de urgencia</th>
                            <th>Tiempo de respuesta</th>
                            <th>Categoria</th>
                            <th>Problema</th>
                            <th>Resolución</th>
                            <th>Asignado</th>
                            <th>Registro</th>
                            <th>Cierre/Modif</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap4.min.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>

    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap4.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

    <script>
        $(document).ready(function () {

            //// 2. Inicializar DataTable
            //var table = $('#tblReporteMaster').DataTable({
            //    "pageLength": 25,
            //    "order": [],
            //    "responsive": true,
            //    "dom": '<"row"<"col-sm-12 col-md-6"f><"col-sm-12 col-md-6">>rtip',
            //    "buttons": [
            //        {
            //            extend: 'excelHtml5',
            //            title: 'Reporte_Tickets_' + new Date().toLocaleDateString(),
            //            exportOptions: { columns: ':visible' }
            //        },
            //        {
            //            extend: 'pdfHtml5',
            //            title: 'Reporte de Tickets',
            //            orientation: 'landscape',
            //            pageSize: 'LEGAL',
            //            exportOptions: { columns: ':visible' }
            //        }
            //    ],
            //    "language": {
            //        "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
            //    }
            //});
            var table = $('#tblReporteMaster').DataTable({
            processing: true,   // loader
            deferRender: true,  // 🔥 mejora rendimiento
            pageLength: 25,
                order: [],
                orderCellsTop: true,
                responsive: true,
                paging: true,
                pageLength: 10,

            ajax: {
                url: '@Url.Action("ObtenerReporteTickets", "Home")',
                type: 'GET',
                dataSrc: ''
            },

            columns: [
                { data: 'idTicket' },
                { data: 'ususarioSolicitador' },
                { data: 'incidencia' },
                { data: 'caja' },
                { data: 'nivelUrgencia' },
                { data: 'respuesta' },
                { data: 'categoria' },
                {
                    data: 'problema',
                    render: function (data) {
                        return `<span title="${data}">${data}</span>`;
                    }
                },
                {
                    data: 'resolucion',
                    render: function (data) {
                        return `<span title="${data}">${data}</span>`;
                    }
                },
                { data: 'usuarioAsignado' },
                {
                    data: 'registro',
                    render: function (data) {
                        return data ? new Date(data).toLocaleString() : 'N/A';
                    }
                },
                {
                    data: 'modificacion',
                    render: function (data) {
                        return data ? new Date(data).toLocaleString() : 'N/A';
                    }
                },
                {
                    data: 'estado',
                    render: function (data) {
                        let clase = (data === "Pendiente") ? "badge-warning"
                            : (data === "Cerrado") ? "badge-success"
                                : "badge-info";

                        return `<span class="badge ${clase}">${data}</span>`;
                    }
                }
            ],

            language: {
                processing: "Cargando datos...",
                url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
            }
        });

            // 3. Eventos de los botones externos
            $('#btnExportarExcel').on('click', function () { table.button(0).trigger(); });
            $('#btnExportarPDF').on('click', function () { table.button(1).trigger(); });

            // Clonar header para filtros
            $('#tblReporteMaster thead tr').clone(true).appendTo('#tblReporteMaster thead');

            $('#tblReporteMaster thead tr:eq(1) th').each(function (i) {
                var title = $(this).text();

                $(this).html('<input type="text" class="form-control form-control-sm" placeholder="' + title + '" />');

                $('input', this).on('keyup change', function () {
                    if (table.column(i).search() !== this.value) {
                        table.column(i).search(this.value).draw();
                    }
                });
            });
        });


    </script>

}
