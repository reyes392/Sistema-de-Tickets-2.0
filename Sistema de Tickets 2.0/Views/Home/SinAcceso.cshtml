
@{
    Layout = null;
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Sistema_de_Tickets_2._0.styles.css" asp-append-version="true" />
@*<title>SB Admin 2 - Cards</title>*@

<!-- Custom fonts for this template-->
<link href="~/sbadmin2/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
<link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
      rel="stylesheet">

<!-- Custom styles for this template-->
<link href="~/sbadmin2/css/sb-admin-2.min.css" rel="stylesheet">
<div class="container mt-5">
    <div class="card text-center">
        <div class="card-header bg-warning text-dark">
            <i class="fas fa-exclamation-triangle me-1"></i> Acceso Denegado
        </div>
        <div class="card-body">
            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning">@ViewBag.Mensaje</div>
            }
            else
            {
                <p>No tienes permisos suficientes para acceder a esta sección, contactate con el administrador.</p>
            }

            @*<a href="@Url.Action("Index","Acceso")" class="btn btn-primary mt-3">
                    <i class="fas fa-home me-1"></i> Volver al Login
                </a>*@

            <a asp-controller="Acceso"
               asp-action="Login"
               class="btn btn-primary">
                Volver al inicio de sesion
            </a>
        </div>
    </div>
</div>
<!-- Bootstrap core JavaScript-->
<script src="~/sbadmin2/vendor/jquery/jquery.min.js"></script>
<script src="~/sbadmin2/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="~/sbadmin2/js/demo/datatables-demo.js"></script>
<!-- Core plugin JavaScript-->
<script src="~/sbadmin2/vendor/jquery-easing/jquery.easing.min.js"></script>

<!-- Custom scripts for all pages-->
<script src="~/sbadmin2/js/sb-admin-2.min.js"></script>




<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>