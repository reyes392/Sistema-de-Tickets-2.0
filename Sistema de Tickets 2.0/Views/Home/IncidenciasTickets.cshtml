@model List<E_Tipos_Incidencias_Tickets>
@using Capa_Entidad.Tickets
@{
    ViewData["Title"] = "IncidenciasTickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<h1 class="text-center">Tipos de Incidencias</h1>

<button class="btn btn-primary mb-3 " data-bs-toggle="modal" data-bs-target="#modalRegistro" onclick="abrirModal('INSERT')">
    <i class="fas fa-plus">  Nuevo Registro</i>
</button>

<div class="table-responsive shadow">
    <table class="table table-bordered table-striped" id="tblTiposIncidencias">
        <thead class="table-dark">
            <tr>
                <th>Descripcion</th>
                <th>Estado</th>
                <th>Nivel de Urgencia</th>
                <th>Tiempo de Respuesta</th>
                <th>Registro</th>
                <th>Modificacion</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr data-id="@u.IdTiposIncidenciasTickets">
                    <td>@u.Descripcion</td>
                    <td>@u.Estado</td>
                    <td>@u.NivelUrgencia</td>
                    <td>@u.TiempoRespuesta</td>
                    <td>@u.FechaRegistro</td>
                    <td>@u.FechaModificacion</td>
             
                    <td>
                        <button class="btn btn-sm btn-warning"
                                data-bs-toggle="modal"
                                data-bs-target="#modalRegistro"
                                data-id="@u.IdTiposIncidenciasTickets"
                                data-descripcion="@u.Descripcion"
                                data-estado="@u.Estado"
                                data-urgencia="@u.NivelUrgencia"
                           
               
                                onclick="abrirModal('UPDATE', this)">
                            @*Editar*@
                            <i class="fas fa-edit">  Editar</i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal fade" id="modalRegistro" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="formRegistro">
                <div class="modal-header">
                    <h5 class="modal-title" id="tituloModal"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="IdTiposIncidenciasTickets" name="IdTiposIncidenciasTickets" />
                    <input type="hidden" id="Accion" name="Accion" />

                    <div class="mb-2">
                        <label>Descripcion</label>
                        <input type="text" class="form-control" id="Descripcion" name="Descripcion" required />
                    </div>

                    <div class="mb-2">
                        <label>Estado</label>
                        <select id="IdEstado" name="IdEstado" class="form-select">
                            @foreach (var e in ViewBag.Estados)
                            {
                                <option value="@e.IdEstado">@e.Descripcion</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label>Categoría</label>
                        <select id="IdNivelUrgencia" name="IdNivelUrgencia" class="form-select">
                            @foreach (var c in ViewBag.Urgencia)
                            {
                                <option value="@c.IdNivelesUrgencia">@c.Descripcion</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Guardar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Incluye SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
    function abrirModal(accion, boton = null) {
        document.getElementById("Accion").value = accion;
        document.getElementById("tituloModal").innerText = accion === 'INSERT' ? "Nueva Incidencia" : "Editar Incidencia";

        if (accion === 'UPDATE' && boton) {
            document.getElementById("IdTiposIncidenciasTickets").value = boton.dataset.id;
            document.getElementById("Descripcion").value = boton.dataset.descripcion;
            setDropdownValue("IdEstado", boton.dataset.estado);
            setDropdownValue("IdNivelUrgencia", boton.dataset.urgencia);

        } else {
            document.getElementById("formRegistro").reset();
        }
    }

    function setDropdownValue(id, text) {
        let select = document.getElementById(id);
        for (let i = 0; i < select.options.length; i++) {
            if (select.options[i].text === text) {
                select.selectedIndex = i;
                break;
            }
        }
    }

    // Guardar usuario por AJAX con SweetAlert
        document.getElementById("formRegistro").addEventListener("submit", function (e) {
        e.preventDefault();

        let formData = new FormData(this);

        fetch('@Url.Action("GuardaIncidenciasTickets", "Home")', {
            method: 'POST',
            body: formData,
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Éxito',
                    text: data.mensaje,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => location.reload());
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: data.mensaje
                });
            }
        })
        .catch(err => console.error(err));
    });
    </script>
}


