@model List<Capa_Entidad.Canjes.E_Canje>
@using Capa_Entidad.Canjes
@{
    ViewData["Title"] = "ReportesCanjes";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var listaReclamos = Model ?? new List<E_Canje>();
}




<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 mt-3">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-chart-line text-primary"></i> Reporte General de Canjes</h1>

        <div id="buttonsContainer">
            <button id="btnExportarExcel" class="btn btn-success btn-sm shadow-sm">
                <i class="fas fa-file-excel"></i> Exportar a Excel
            </button>
            <button id="btnExportarPDF" class="btn btn-danger btn-sm shadow-sm">
                <i class="fas fa-file-pdf"></i> Exportar a PDF
            </button>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Panel de Filtros</h6>
        </div>
        <div class="card-body bg-light">
            <div class="row">
                <div class="col-md-3 mb-2">
                    <label class="small font-weight-bold">Rango de Fechas (Registro)</label>
                    <div class="input-group input-group-sm">
                        <input type="date" id="min" class="form-control" placeholder="Desde">
                        <input type="date" id="max" class="form-control">
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <label class="small font-weight-bold">Filtrar por Estado</label>
                    <select id="selectEstado" class="form-control form-control-sm">
                        <option value="">Todos los estados</option>
                        <option value="Pendiente">Pendiente</option>
                        <option value="En Proceso">En Proceso</option>
                        <option value="Cerrado">Cerrado</option>
                    </select>
                </div>
                <div class="col-md-3 mb-2">
                    <label class="small font-weight-bold">Técnico Asignado</label>
                    <input type="text" id="buscTecnico" class="form-control form-control-sm" placeholder="Nombre del técnico...">
                </div>
                <div class="col-md-3 mb-2 d-flex align-items-end">
                    <button class="btn btn-secondary btn-sm btn-block" onclick="limpiarFiltros()">
                        <i class="fas fa-eraser"></i> Limpiar Filtros
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped w-100" id="tblReporteMaster" width="100%" cellspacing="0">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Usuario Asignado</th>
                            <th>Tipo de Incidencia</th>
                            <th>Solicitador</th>
                            <th>Fecha Registro</th>
                            <th>Autorizado por:</th>
                            <th>Fecha Autorizado</th>
                            <th>Anulador</th>
                            <th>Fecha Anulado</th>
                            <th>Descripcion Problema</th>
                            <th>Resolucion</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in listaReclamos)
                        { // Usamos la lista segura
                            <tr>
                                <td class="font-weight-bold">@t.IdCanje</td>
                                <td>@t.NombreSolicitador</td>
                                <td><span class="small">@t.NombreAsignado</span></td>
                                <td class="small">@t.TipoIncidencia</td>
                                <td class="small text-truncate" style="max-width: 150px;" title="@t.DescripcionProblema">@t.DescripcionProblema</td>
                                <td class="small text-truncate" style="max-width: 150px;" title="@t.Resolucion">@t.Resolucion</td>
                                <td class="small">@t.FechaRegistro</td>

                                <td>@t.NombreAutorizador</td>
                                <td class="small">@t.FechaAutorizado</td>
                                <td>@t.NombreAnulador</td>
                                <td class="small">@t.FechaAnulado</td>









                                <td>
                                    @{ var claseEstado = t.Estado == "Pendiente" ? "badge-warning" : (t.Estado == "Cerrado" ? "badge-success" : "badge-info"); }
                                    <span class="badge @claseEstado">@t.Estado</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap4.min.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>

    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap4.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Filtro de Fechas Personalizado
            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
                var min = $('#min').val();
                var max = $('#max').val();

                // La fecha de registro en Canjes está en la columna 4
                var dateStr = data[4] || "";

                if (!min && !max) return true;

                try {
                    // Convertimos DD/MM/YYYY a YYYY-MM-DD
                    var parts = dateStr.split(' ')[0].split('/');
                    var actualDate = parts[2] + "-" + parts[1] + "-" + parts[0];

                    if (min && actualDate < min) return false;
                    if (max && actualDate > max) return false;
                    return true;
                } catch (e) {
                    return true;
                }
            });

            // 2. Inicializar DataTable
            var table = $('#tblReporteMaster').DataTable({
                "pageLength": 25,
                "order": [[0, "desc"]],
                "responsive": true,
                "dom": '<"row"<"col-sm-12 col-md-6"f><"col-sm-12 col-md-6">>rtip',
                "buttons": [
                    {
                        extend: 'excelHtml5',
                        title: 'Reporte_Canjes_' + new Date().toLocaleDateString(),
                        exportOptions: { columns: ':visible' }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: 'Reporte de Canjes',
                        orientation: 'landscape',
                        pageSize: 'LEGAL',
                        exportOptions: { columns: ':visible' }
                    }
                ],
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }
            });

            // 3. Botones de exportación
            $('#btnExportarExcel').on('click', function () { table.button(0).trigger(); });
            $('#btnExportarPDF').on('click', function () { table.button(1).trigger(); });

            // 4. Filtros corregidos

            // Estado está en la columna 11
            $('#selectEstado').on('change', function () {
                table.column(11).search(this.value).draw();
            });

            // Técnico/Usuario Asignado está en la columna 1
            $('#buscTecnico').on('keyup', function () {
                table.column(1).search(this.value).draw();
            });

            // Redibujar al cambiar fechas
            $('#min, #max').on('change', function () {
                table.draw();
            });
        });

        function limpiarFiltros() {
            $('#min, #max, #buscTecnico, #selectEstado').val('');
            var table = $('#tblReporteMaster').DataTable();
            table.search('').columns().search('').draw();
        }
    </script>
}