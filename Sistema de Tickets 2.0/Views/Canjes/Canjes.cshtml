@model List<Capa_Entidad.Canjes.E_Canje>

@{
    ViewData["Title"] = "Gestión de Canjes";
}
<style>
    /* Estilos para el Chat */
    #chatBox {
        height: 350px;
        overflow-y: auto;
        background-color: #f8f9fa;
        display: flex;
        flex-direction: column;
        padding: 15px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        gap: 12px;
    }

    .chat-message {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 10px;
        position: relative;
        font-size: 0.9rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .chat-left {
        align-self: flex-start;
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        color: #333;
    }

    .chat-right {
        align-self: flex-end;
        background-color: #0d6efd;
        color: white;
    }

    .chat-time {
        font-size: 0.65rem;
        display: block;
        margin-top: 4px;
        opacity: 0.7;
    }

    .chat-user {
        font-size: 0.7rem;
        font-weight: bold;
        display: block;
        margin-bottom: 2px;
    }

    .notif-badge {
        font-size: 0.6rem;
        padding: 4px 6px;
        margin-left: 5px;
        animation: pulse 1.5s infinite; /* Acelerado un poco para mejor visibilidad */
    }
    /* Si el mensaje empieza con el icono de pin, le damos un estilo de "tarjeta" */
    .chat-message:contains("📌") {
        background-color: #fff3cd !important; /* Amarillo claro tipo nota */
        border: 1px border-left: 5px solid #ffc107 !important;
        color: #856404 !important;
        white-space: pre-line; /* Para que respete los saltos de línea */
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            opacity: 1;
        }
    }


    /* ===== TEXTO GENERAL ===== */
    body {
        color: #212529;
    }

    /* Labels y títulos */
    label, .form-label, strong {
        color: #1a1a1a;
    }

    /* Texto secundario */
    .text-muted {
        color: #6c757d !important;
    }

    /* ===== TABLAS (SOLO TEXTO) ===== */
    .table td {
        color: #2c2c2c;
    }

    .table th {
        font-weight: 600;
        color: #ffffff; /* asegura buen contraste en header oscuro */
    }

    /* ===== DETALLE DERECHO ===== */
    #seccionDetalle {
        background-color: #f4f6f9;
    }

    /* Inputs */
    .form-control {
        color: #000;
    }

    /* Textarea readonly */
    textarea[readonly] {
        background-color: #f8f9fa;
        color: #333;
    }

    /* ===== BOTONES ===== */
    .btn {
        font-weight: 500;
    }

</style>

