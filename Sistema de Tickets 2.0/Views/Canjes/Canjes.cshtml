<div class="container-fluid mt-3">
    <div class="row">
        @* --- LISTADO DE CANJES --- *@
        <div class="col-md-6 border-end">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-exchange-alt"></i> Listado de Canjes</h2>
                <button class="btn btn-primary shadow-sm" onclick="abrirModalNuevo()">
                    <i class="fas fa-plus-circle"></i> Nuevo Canje
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover shadow-sm border" id="tblCanjes">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Solicitante</th>
                            <th>Incidencia</th>
                            <th>Registro</th>
                            <th>Estado</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                      
                    </tbody>
                </table>
            </div>
        </div>

        @* --- DETALLE DEL CANJE --- *@
        <div class="col-md-6 bg-light p-4" id="seccionDetalle" style="display:none; min-height: 85vh;">
            <ul class="nav nav-tabs" id="canjeTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#info" type="button">
                        <i class="fas fa-info-circle"></i> Gestión
                    </button>
                </li>
                <li class="nav-item">
                    @* Asegurar que el click recarga el chat *@
                    <button class="nav-link fw-bold" id="tabChat" data-bs-toggle="tab" data-bs-target="#chatTab" type="button" onclick="cargarChat()">
                        <i class="fas fa-comments"></i> Chat / Notas
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#adjuntosTab" type="button" onclick="recarcarAdjuntosActuales()">
                        <i class="fas fa-paperclip"></i> Adjuntos
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-4 bg-white shadow-sm">
                @* Pestaña Información *@
                <div class="tab-pane fade show active" id="info">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-primary m-0">Canje #<span id="lblIdCanje"></span></h5>
                        <span id="badgeEstado" class="badge p-2"></span>
                    </div>

                    <div class="row g-2 mb-4 border-bottom pb-3">
                        <div class="col-6 small text-primary"><strong>Solicitante:</strong> <span id="txtSolicitante" class="d-block fw-bold"></span></div>
                        <div class="col-6 small text-primary"><strong>Incidencia:</strong> <span id="txtIncidencia" class="d-block fw-bold"></span></div>
                        <div class="col-6 small text-primary"><strong>Asignado a:</strong> <span id="txtAsignado" class="d-block fw-bold"></span></div>
                        <div class="col-6 small text-primary"><strong>Fecha Registro:</strong> <span id="txtFechaRegistro" class="d-block fw-bold"></span></div>
                        <div class="col-6 small border-top mt-2 pt-2 text-primary"><strong>Caja:</strong> <span id="txtCaja" class="d-block fw-bold"></span></div>
                        <div class="col-6 small border-top mt-2 pt-2 text-primary"><strong>Monto:</strong> <span id="txtMonto" class="d-block fw-bold"></span></div>
                        <div class="col-6 small text-primary"><strong># Factura:</strong> <span id="txtFactura" class="d-block fw-bold"></span></div>
                        <div class="col-6 small text-primary"><strong>Fecha Factura:</strong> <span id="txtFechaFactura" class="d-block fw-bold"></span></div>
                        <div class="col-6 small border-top mt-2 pt-2"><strong>Autorizado por:</strong> <span id="txtAutorizador" class="d-block text-success"></span></div>
                        <div class="col-6 small text-primary border-top mt-2 pt-2"><strong>Fecha Autorizado:</strong> <span id="txtFechaAutorizado" class="d-block text-muted"></span></div>
                        <div class="col-6 small"><strong>Anulado por:</strong> <span id="txtAnulador" class="d-block text-danger"></span></div>
                        <div class="col-6 small text-primary"><strong>Fecha Anulado:</strong> <span id="txtFechaAnulado" class="d-block fw-bold"></span></div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small ">Descripción del Problema:</label>
                        <div id="divDescripcionDetalle" class="p-2 border rounded bg-light" style="min-height: 60px; white-space: pre-wrap;"></div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small">Resolución:</label>
                        <textarea id="txtResolucion" class="form-control border-success" rows="4"></textarea>
                    </div>
                    @if (ViewBag.RolUsuario == 1 || ViewBag.RolUsuario == 7 || ViewBag.RolUsuario == 6)
                    {
                        <div id="contenedorBotonGuardar">

                            <button id="btnGuardarCanje" class="btn btn-success w-100" onclick="guardarCambiosCanje()">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>

                        </div>
                    }

                </div>

                @* Pestaña Chat *@
                <div class="tab-pane fade" id="chatTab">
                    <div id="chatBox"></div>
                    <div id="divPreviewChat" class="mt-2" style="display:none;">
                        <span class="badge bg-info text-dark">
                            <i class="fas fa-paperclip"></i> <span id="lblNombreArchivoChat"></span>
                            <i class="fas fa-times ms-2" style="cursor:pointer" onclick="limpiarArchivoChat()"></i>
                        </span>
                    </div>
                    <div class="input-group mt-3" id="contenedorEscrituraChat">
                        @*// Busca donde tienes el input-group del chat y añade este botón:*@
                        @if (ViewBag.RolUsuario == 1 || ViewBag.RolUsuario == 7)
                        {
                            <button class="btn btn-outline-info" type="button" onclick="$('#modalSolicitarInfo').modal('show')">
                                <i class="fas fa-list-check">Solicitar info</i>
                            </button>
                        }
                        <input type="file" id="fArchivoChat" style="display:none" onchange="seleccionarArchivoChat(this)" />
                        <button class="btn btn-outline-secondary" type="button" onclick="$('#fArchivoChat').click()">
                            <i class="fas fa-paperclip"></i>
                        </button>

                        <input type="text" id="txtMensajeChat" class="form-control" placeholder="Escribe un comentario..." onkeypress="if(event.keyCode==13) enviarComentario()">
                        <button class="btn btn-primary" type="button" onclick="enviarComentario()">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>

                <div class="tab-pane fade" id="adjuntosTab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold"><i class="fas fa-file-alt"></i> Archivos del Canje</h6>
                    </div>

                    <div id="listaAdjuntos" class="list-group shadow-sm">
                        <div class="p-3 text-center text-muted small">Cargando archivos...</div>
                    </div>
                </div>


            </div>
        </div>

        <div class="col-md-6 d-flex align-items-center justify-content-center bg-light border" id="detalleVacio" style="min-height: 85vh;">
            <div class="text-center text-muted">
                <i class="fas fa-mouse-pointer fa-3x mb-3"></i>
                <p>Selecciona un canje de la lista para ver el detalle</p>
            </div>
        </div>
    </div>
</div>

