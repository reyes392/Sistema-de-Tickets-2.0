            $("#modalNuevoCanje").modal("show");
        }
        function enviarSolicitudEstructurada() {
            const cuerpo = $("#txtInfoRequerida").val().trim();
            if (cuerpo === "") return;

            // Consolidamos la información con un formato visual
            const mensajeConsolidado = `📌 **SOLICITUD DE INFORMACIÓN**\n\n${cuerpo}\n\n*Por favor, responder a la brevedad.*`;

            let formData = new FormData();
            formData.append("idCanje", getId(state.canjeSeleccionado));
            formData.append("mensaje", mensajeConsolidado);
            // No enviamos archivo en esta modalidad estructurada

            $.ajax({
                url: '@Url.Action("GuardarComentario", "Canjes")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function(res) {
                    if (res.success) {
                        $("#txtInfoRequerida").val(""); // Limpiar modal
                        $("#modalSolicitarInfo").modal("hide");
                        actualizarChatSilencioso(); // Refrescar chat
                    }
                }
            });
        }

        function abrirFormularioRespuesta(base64Msg) {
            const mensaje = decodeURIComponent(escape(atob(base64Msg)));
            const lineas = mensaje.split('\n').filter(l => l.trim().startsWith('-'));

            let htmlInputs = "";
            lineas.forEach((l) => {
                const label = l.replace('-', '').trim();
                if (label !== "") {
                    const esFoto = label.toLowerCase().includes("foto");

                    htmlInputs += `
            <div class="mb-3">
                <label class="form-label fw-bold small text-uppercase">${label}</label>
                ${esFoto ?
                            `<input type="file" class="form-control input-respuesta-file" data-label="${label}" accept="image/*">` :
                            `<input type="text" class="form-control input-respuesta" data-label="${label}" placeholder="Escriba aquí...">`
                        }
            </div>`;
                }
            });

            if (htmlInputs === "") {
                htmlInputs = `<div class="text-center py-3"><p class='text-muted'>Formato no válido.</p></div>`;
            }

            $("#contenedorCamposDinamicos").html(htmlInputs);
            $("#modalResponderInfo").modal("show");
        }
        // Envía la respuesta consolidada de vuelta al chat
         function enviarRespuestaConsolidada() {
            let respuestaFinal = "✅ **INFORMACIÓN PROPORCIONADA:**\n";
            let completo = true;
            let archivoAdjunto = null;
            const $btn = $("#modalResponderInfo .btn-success");

            // 1. Recoger textos
            $(".input-respuesta").each(function () {
                const val = $(this).val().trim();
                const label = $(this).data("label");
                if (val === "") { $(this).addClass("is-invalid"); completo = false; }
                else { $(this).removeClass("is-invalid"); respuestaFinal += `\n* ${label}: ${val}`; }
            });

            // 2. Recoger Archivo (Foto)
            $(".input-respuesta-file").each(function () {
                const label = $(this).data("label");
                if (this.files.length > 0) {
                    archivoAdjunto = this.files[0];
                    respuestaFinal += `\n* ${label}: (Imagen adjunta en este mensaje)`;
                } else {
                    $(this).addClass("is-invalid");
                    completo = false;
                }
            });

            if (!completo) {
                Swal.fire('Atención', 'Por favor complete todos los campos, incluyendo la foto', 'warning');
                return;
            }

            let formData = new FormData();
            formData.append("idCanje", getId(state.canjeSeleccionado));
            formData.append("mensaje", respuestaFinal);
            if (archivoAdjunto) {
                formData.append("archivo", archivoAdjunto); // Se envía al mismo Action que el chat normal
            }

            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Enviando...');

            $.ajax({
                url: '@Url.Action("GuardarComentario", "Canjes")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function(res) {
                    if (res.success) {
                        $("#modalResponderInfo").modal("hide");
                        actualizarChatSilencioso();
                    }
                    $btn.prop('disabled', false).text('Enviar Datos');
                },
                error: function() {
                    $btn.prop('disabled', false).text('Enviar Datos');
                    Swal.fire('Error', 'No se pudo enviar', 'error');
                }
            });
        }
        function actualizarContadoresCards() {
            // 1. Validar que la tabla y el contador existan
            if (!tablaCanjes || $('#card-total-abiertos').length === 0) return;

            // 2. Obtener todos los datos cargados en la tabla (no solo los visibles)
            let todosLosDatos = tablaCanjes.data();

            let abiertos = 0;
            let proceso = 0;
            let cerrados = 0;

            // 3. Recorrer el array de objetos JSON directamente
            todosLosDatos.each(function (row) {
                // Usamos el nombre de la propiedad tal cual viene del servidor (minúscula o mayúscula según tu C#)
                let estado = (row.estado || row.Estado || "").toString().trim().toLowerCase();

                if (estado === "pendiente") abiertos++;
                else if (estado === "en proceso") proceso++;
                else if (estado === "cerrado") cerrados++;
            });

            // 4. Actualizar las Cards con animación (opcional pero elegante)
            $("#card-total-abiertos").text(abiertos);
            $("#card-total-proceso").text(proceso);

            // Log para depuración en consola
            console.log(`Contadores actualizados: Pendientes: ${abiertos}, Proceso: ${proceso}`);
        }



         function recarcarAdjuntosActuales() {
            // Obtenemos el ID del estado global que ya manejas
            const id = state.canjeSeleccionado.idCanje || state.canjeSeleccionado.IdCanje;
            if (id) {
                cargarAdjuntos(id);
            }
        }

        function cargarAdjuntos(id) {
            // Si recibimos el objeto completo, extraemos el ID
            const idLimpio = (typeof id === 'object') ? (id.idCanje || id.IdCanje) : id;

            // IMPORTANTE: El nombre del parámetro debe ser 'idCanjes' para que coincida con tu [HttpGet] de C#
            $.get('@Url.Action("ObtenerAdjuntos", "Canjes")', { idCanjes: idLimpio }, function(data) {
                if (!data || data.length === 0) {
                    $("#listaAdjuntos").html('<div class="p-3 text-center text-muted small">No hay archivos adjuntos</div>');
                    return;
                }

                let html = data.map(x => `
                    <a href="${x.ruta.replace('~','')}" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center p-2">
                        <i class="fas fa-file-alt text-primary me-3"></i>
                        <div class="text-truncate small fw-bold">${x.nombreOriginal}</div>
                    </a>`).join('');

                $("#listaAdjuntos").html(html);
            }).fail(function() {
                $("#listaAdjuntos").html('<div class="p-3 text-center text-danger small">Error al conectar con el servidor</div>');
            });
        }


    </script>
}