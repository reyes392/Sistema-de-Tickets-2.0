        function actualizarUIEstado(canje) {
            // Aseguramos que el ID del estado sea un número
            const idEstado = parseInt(canje.IdEstado || canje.idEstado || 0);
            const miRol = parseInt(user.rol);
            const est = (canje.Estado || "").trim().toLowerCase();

            // 1. Badge de Estado
            const colores = {
                "pendiente": "bg-warning text-dark",
                "en proceso": "bg-info text-white",
                "cerrado": "bg-success text-white",
                "autorizado": "bg-success text-white",
                "anulado": "bg-danger text-white"
            };
            $("#badgeEstado").text(est.toUpperCase()).attr("class", "badge p-2 " + (colores[est] || "bg-secondary"));

            // 2. Renderizado de Botones
            let htmlBotones = '';

            // CONDICIÓN PARA BOTÓN ANULAR (Si es Autorizado Y soy Rol 1 o 6)
            if (idEstado === 6 && (miRol === 1 || miRol === 6)) {
                htmlBotones = `<button class="btn btn-danger w-100" onclick="anularCanje()">
                         <i class="fas fa-ban"></i> Anular Canje (Call Center)
                       </button>`;
            }
            // CONDICIÓN PARA BOTÓN GUARDAR (Si NO es finalizado Y soy Staff operativo)
            else if (idEstado !== 6 && idEstado !== 7 && user.isStaff()) {
                htmlBotones = `<button class="btn btn-success w-100" onclick="guardarCambiosCanje()">
                         <i class="fas fa-save"></i> Guardar Cambios
                       </button>`;
            }

            $("#contenedorBotonGuardar").html(htmlBotones);

            // 3. Control del Chat
            if (idEstado === 6 || idEstado === 7) {
                $("#contenedorEscrituraChat").hide();
            } else {
                $("#contenedorEscrituraChat").show();
            }
        }

        // --- 5. FUNCIONES DE CHAT ---

        function cargarChat() {
            if (!state.canjeSeleccionado) return;
            const id = getId(state.canjeSeleccionado);

            // Reseteo para evitar que crea que son los mensajes del canje anterior
            ultimaCantidadComentarios = 0;
            $("#chatBox").html('<div class="text-center p-5"><i class="fas fa-spinner fa-spin fa-2x text-primary"></i></div>');

            if (state.chatTimer) clearInterval(state.chatTimer);

            actualizarChatSilencioso();

            state.chatTimer = setInterval(() => {
                // Solo actualizar si la pestaña del chat está visible
                if ($("#chatTab").hasClass("active")) {
                    actualizarChatSilencioso();
                }
            }, 5000);
        }


        window.verImagenFull = function(url) {
            if (url) window.open(url, '_blank');
        };

        function limpiarArchivoChat() {
            $("#fArchivoChat").val("");
            $("#containerMiniaturaChat").remove();
            $("#divPreviewChat").hide();
            $("#lblNombreArchivoChat").text("");
        }

        function seleccionarArchivoChat(input) {
            if (input.files.length > 0) {
                const file = input.files[0];
                $("#lblNombreArchivoChat").text(file.name);
                $("#divPreviewChat").show();

                // Si es imagen, generar miniatura con botón X
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        let previewHtml = `
                            <div id="containerMiniaturaChat" style="position: relative; display: inline-block; margin-bottom: 8px;">
                                <img id="imgMiniaturaChat" src="${e.target.result}"
                                     style="max-height: 70px; border-radius: 5px; border: 2px solid #0d6efd; display: block;">
                                <span onclick="limpiarArchivoChat()"
                                      style="position: absolute; top: -8px; right: -8px; background: #ef4444; color: white;
                                             border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center;
                                             justify-content: center; font-size: 12px; cursor: pointer; border: 2px solid white; z-index: 10;">
                                    <i class="fas fa-times"></i>
                                </span>
                            </div>`;

                        if ($("#containerMiniaturaChat").length > 0) {
                            $("#containerMiniaturaChat").replaceWith(previewHtml);
                        } else {
                            $("#divPreviewChat").prepend(previewHtml);
                        }
                    };
                    reader.readAsDataURL(file);
                } else {
                    $("#containerMiniaturaChat").remove();
                }
            }
        }

        // --- 2. ACTUALIZACIÓN DEL CHAT (MULTIMEDIA) ---
        function verificarSiQuedanNotificaciones() {
            // Si no hay ningún badge visible en la tabla, detenemos el parpadeo
            if ($(".badge-notif:not(.d-none)").length === 0) {
                detenerParpadeoTitulo();
            }
        }
        function actualizarChatSilencioso() {
            if (!state.canjeSeleccionado) return;
            const id = getId(state.canjeSeleccionado);

            $.get('@Url.Action("ObtenerComentarios", "Canjes")', { idCanje: id }, function (data) {

                // 1. Manejo de estado vacío
                if (!data || data.length === 0) {
                    if (ultimaCantidadComentarios !== 0) {
                        $("#chatBox").html('<div class="text-center text-muted small mt-4">No hay mensajes en este canje.</div>');
                        ultimaCantidadComentarios = 0;
                    }
                    return;
                }

                // 2. Si la cantidad no ha cambiado, evitamos repintar el DOM (adiós parpadeo)
                /*  if (data.length === ultimaCantidadComentarios) return;*/
                if (data.length > ultimaCantidadComentarios) {
                    $("#chatBox").animate({ scrollTop: $("#chatBox")[0].scrollHeight }, 300);

                    // En lugar de hacer otro $.get, tomamos el ID del último mensaje del array 'data'
                    const ultimoMsg = data[data.length - 1];
                    const ultimoIdRemoto = ultimoMsg.idComentario || ultimoMsg.IdComentario; // Ajusta según tu E_Comentario

                    guardarLecturaLocal(id, ultimoIdRemoto);

                    // Ocultamos el badge inmediatamente ya que lo estamos viendo
                    $(`#notif-${id}`).addClass("d-none");

                    // Verificamos si debemos detener el parpadeo del título
                    verificarSiQuedanNotificaciones();
                }

                let html = "";
                data.forEach(c => {
                    const esMio = c.esMio;
                    const claseMio = esMio ? "chat-right" : "chat-left";
                    const ruta = c.rutaArchivo || c.RutaArchivo;
                    const ext = (ruta ? ruta.split('.').pop().toLowerCase() : "");
                    const nombreFoto = c.fotoPerfil || c.FotoPerfil;

                    // Lógica de Foto de Perfil
                    const fotoUrl = (nombreFoto && nombreFoto.trim() !== "")
                        ? `/uploads/perfiles/${nombreFoto}`
                        : `/sbadmin2/img/undraw_profile.svg`;

                    // Lógica de Solicitud Estructurada (La mantenemos de tu versión anterior)
                    const esEstructurado = c.mensaje && c.mensaje.includes("📌");
                    const msgBase64 = btoa(unescape(encodeURIComponent(c.mensaje)));
                    const estiloExtra = esEstructurado ? `style="cursor:pointer; border-left: 5px solid #ffc107;" onclick="abrirFormularioRespuesta('${msgBase64}')"` : '';
                    const badgeInfo = esEstructurado ? '<br><small class="badge bg-warning text-dark"><i class="fas fa-edit"></i> Clic para responder</small>' : '';

                    html += `
                        <div class="d-flex ${esMio ? 'flex-row-reverse' : ''} mb-3">
                            <img src="${fotoUrl}"
                                 class="rounded-circle border shadow-sm"
                                 style="width: 35px; height: 35px; object-fit: cover; flex-shrink: 0; ${esMio ? 'margin-left: 10px;' : 'margin-right: 10px;'}"
                                 onerror="this.src='/sbadmin2/img/undraw_profile.svg'">

                            <div class="chat-message ${claseMio}" ${estiloExtra} style="max-width: 80%;">
                                <span class="chat-user">${c.nombreUsuario || "Usuario"}</span>
                                <div>${c.mensaje || ""} ${badgeInfo}</div>`;

                    // Lógica Multimedia
                    if (ruta) {
                        if (ext.match(/(mp4|webm|ogg)$/i)) {
                            html += `
                                <div class="mt-2">
                                    <a href="${ruta}" target="_blank" class="btn btn-sm btn-outline-danger shadow-sm d-inline-flex align-items-center">
                                        <i class="fas fa-play-circle fa-2x me-2"></i>
                                        <div class="text-start">
                                            <small class="d-block fw-bold">Ver Video</small>
                                            <span style="font-size: 0.65rem;">Click para reproducir</span>
                                        </div>
                                    </a>
                                </div>`;
                        } else if (ext.match(/(jpg|jpeg|png|gif)$/i)) {
                            html += `<div class="mt-2"><img src="${ruta}" class="img-fluid rounded border shadow-sm" style="max-height:150px; cursor:pointer;" onclick="verImagenFull('${ruta}')"></div>`;
                        } else {
                            html += `<div class="mt-2"><a href="${ruta}" target="_blank" class="btn btn-sm btn-light border small text-dark"><i class="fas fa-file-download"></i> Documento</a></div>`;
                        }
                    }

                    html += `   <span class="chat-time">${c.fecha || ""}</span>
                            </div>
                        </div>`;
                });

                $("#chatBox").html(html);

                // 3. Scroll inteligente: Solo baja si hay mensajes nuevos
                if (data.length > ultimaCantidadComentarios) {
                    $("#chatBox").animate({ scrollTop: $("#chatBox")[0].scrollHeight }, 300);

                    // Marcar lectura localmente
                    $.get('@Url.Action("ObtenerEstadoChat", "Canjes")', { idCanje: id }, function (res) {
                        guardarLecturaLocal(id, res.ultimoId);
                    });
                }

                ultimaCantidadComentarios = data.length;
            });
        }

        function enviarComentario() {
            const msg = $("#txtMensajeChat").val().trim();
            const file = $("#fArchivoChat")[0].files[0];
            if (!msg && !file) return;

            let formData = new FormData();
            formData.append("idCanje", getId(state.canjeSeleccionado));
            formData.append("mensaje", msg);
            if (file) formData.append("archivo", file);

            $.ajax({
                url: '@Url.Action("GuardarComentario", "Canjes")',
                type: "POST", data: formData, contentType: false, processData: false,
                success: function(res) {
                    if (res.success) {
                        $("#txtMensajeChat").val("");
                        limpiarArchivoChat();
                        actualizarChatSilencioso();
                    }
                }
            });
        }

