@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let ultimaCantidadComentarios = 0;
        let tablaCanjes = null;
    // --- 1. CONFIGURACIÓN Y USUARIO ---
          const user = {
            id: parseInt('@ViewBag.IdUsuarioLogueado') || 0,
            nombre: '@ViewBag.NombreUsuarioLogueado',
            rol: parseInt('@ViewBag.RolUsuario') || 0,

            isStaff: function() {
                return [1, 6, 7].includes(this.rol);
            },

            canAnular: function() {
                return [1, 6].includes(this.rol);
            }
        };

        let state = {
            canjeSeleccionado: null,
            chatTimer: null,
            intervaloPestaña: null,
            tituloOriginal: document.title,
            versionCanjeActual: "",
            ultimoIdComentarioVisto: JSON.parse(localStorage.getItem('chat_visto_' + user.id)) || {}
        };

        const getId = (obj) => obj ? (obj.IdCanje || obj.idCanje || obj.IDCANJE || 0) : 0;

        // --- 2. INICIALIZACIÓN ---
        $(document).ready(function () {

            // Clonar header para filtros
            $('#tblCanjes thead tr').clone(true).appendTo('#tblCanjes thead');

            $('#tblCanjes thead tr:eq(1) th').each(function (i) {

                // Evitar columna de botón (Acción)
                if (i === 5) {
                    $(this).html('');
                    return;
                }

                var title = $(this).text().trim();

                $(this).html(`<input type="text" class="form-control form-control-sm" placeholder="${title}" />`);
            });

            // 1. Inicializar DataTable
            tablaCanjes = $('#tblCanjes').DataTable({
                destroy: true,
         /*       processing: true,*/
                order: [],
                ajax: {
                    url: '@Url.Action("ObtenerCanjesTabla", "Canjes")',
                    type: 'GET',
                    dataSrc: ''
                },
                columns: [
                    {
                        data: 'idCanje',
                        render: function(data) {
                            return `
                                <div class="d-flex align-items-center">
                                    <span id="notif-${data}" class="badge badge-danger rounded-circle d-none mr-2 shadow-sm" style="padding: 5px 7px;">
                                        <i class="fas fa-envelope" style="font-size: 0.7rem;"></i>
                                    </span>
                                    <span class="fw-bold text-primary">${data}</span>
                             </div>`;
                        }
                    },
                    { data: 'nombreSolicitador' },
                    { data: 'tipoIncidencia' },
                    {
                        data: 'fechaRegistro',
                        //render: function(data) {
                        //    return data ? data : '---'; // O formatear si recibes objeto Date
                        //}
                        render: function (data) {
                            return data ? new Date(data).toLocaleString() : 'N/A';
                        }
                    },
                    {
                        data: 'idEstado',
                        className: 'text-center',
                        render: function (data, type, row) {
                            let color = (data == 3) ? "bg-warning text-dark" : (data == 6 ? "bg-success" : "bg-info");
                            return `<span class="badge ${color}">${row.estado}</span>`;
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            let jsonString = JSON.stringify(row).replace(/"/g, '&quot;');
                            return `<button class="btn btn-sm btn-outline-primary btn-ver" data-info='${jsonString}'>
                                        <i class="fas fa-eye"></i> Ver
                                    </button>`;
                        }
                    }
                ],
                language: { url: "//cdn.datatables.net/plug-ins/1.10.24/i18n/Spanish.json" },
                drawCallback: function () {
                    // 1. Sincronizar visualmente los badges de mensajes (sin hacer nueva petición AJAX)
                    if (typeof sincronizarEstadosChatMasivo === "function") {
                        sincronizarEstadosChatMasivo();
                    }

                    // 2. Ejecutar el conteo de Canjes para actualizar las cards
                    actualizarContadoresCards();

                    // 3. Opcional: Si necesitas monitorear mensajes, usa el que ya está en el setInterval
                    // para no saturar cada vez que se pagina la tabla.
                },
            });
            // Carga inicial de versión
            $.get('@Url.Action("ObtenerVersionCanjes", "Canjes")', v => state.versionCanjeActual = v);

            // Intervalos de monitoreo
            setInterval(verificarCambiosCanje, 15000); // Tabla cada 15 seg
            setInterval(monitorearMensajesNuevos, 7000); // Badges cada 7 seg
            setInterval(refrescarTablaCanjes, 15000); // Badges cada 15 seg
        });
        // Activar filtros por columna
        $('#tblCanjes thead tr:eq(1) th').each(function (i) {

            $('input', this).on('keyup change', function () {

                if (tablaCanjes.column(i).search() !== this.value) {
                    tablaCanjes
                        .column(i)
                        .search(this.value)
                        .draw();
                }

            });

        });
        // --- 3. ACTUALIZACIÓN AUTOMÁTICA DE TABLA ---
        function verificarCambiosCanje() {
            $.get('@Url.Action("ObtenerVersionCanjes", "Canjes")', function (nuevaVersion) {
                if (state.versionCanjeActual !== "" && nuevaVersion !== state.versionCanjeActual) {
                    state.versionCanjeActual = nuevaVersion;
                    refrescarTablaCanjes();
                }
            });
        }
        function refrescarTablaCanjes() {

            if (tablaCanjes) {
                tablaCanjes.ajax.reload(function () {
                    // Si el usuario tenía algo seleccionado, actualizar su info en 'state'
                    if (state.canjeSeleccionado) {
                        const idActual = getId(state.canjeSeleccionado);
                        // Buscar en los nuevos datos de la tabla
                        const nuevaInfo = tablaCanjes.rows().data().toArray().find(x => getId(x) === idActual);
                        if (nuevaInfo) {
                            state.canjeSeleccionado = nuevaInfo;
                            verDetalle(nuevaInfo); // Actualiza textos e badges sin cerrar el panel
                        }
                    }
                }, false); // false = mantener posición del paginado
            }
        }

