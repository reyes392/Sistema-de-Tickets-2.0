        function guardarCambiosCanje() {
            if (!state.canjeSeleccionado) return;

            const res = $("#txtResolucion").val().trim();
            const canje = state.canjeSeleccionado;

            // Paquete completo de datos
            const canjeData = {
                IdCanje: getId(canje), // Ahora sí viajará el ID (ej: 9)
                IdTipoIncidencia: canje.idTipoIncidenciaCanjes || canje.IdTipoIncidenciaCanjes || canje.idTipoIncidencia,
                DescripcionProblema: canje.descripcionProblema || canje.DescripcionProblema,
                Resolucion: res,
                IdEstado: (res !== "") ? 6 : 5,
                // Importante: Re-enviamos los datos financieros para que el SP los mantenga
                Monto: canje.monto || canje.Monto,
                NumeroFactura: canje.numeroFactura || canje.NumeroFactura,
                FechaFactura: canje.fechaFactura || canje.FechaFactura,
                IdCaja: canje.idCaja || canje.IdCaja,
                IdUsuarioAsignado: user.id
            };

            Swal.fire({
                title: '¿Confirmar gestión?',
                text: (res !== "") ? "El canje se marcará como Autorizado" : "Se guardará el progreso",
                icon: 'question',
                showCancelButton: true
            }).then((result) => {
                if (result.isConfirmed) {
                    enviarDatos(canjeData, "UPDATE");
                }
            });
        }


        function crearCanje() {
            const idIncidencia = $("#cboIncidencia").val();
            const descripcion = $("#txtDescripcionNueva").val().trim();
            const monto = $("#txtMontoNueva").val();
            const factura = $("#txtFacturaNueva").val().trim();
            const fechaFactura = $("#txtFechaFacturaNueva").val();
            const idCaja = $("#cboCajaNueva").val();

            // Validaciones
            if (!idIncidencia) {
                Swal.fire('Atención', 'Por favor, seleccione un tipo de incidencia', 'warning');
                return;
            }
            if (descripcion === "") {
                Swal.fire('Atención', 'Por favor, describa el problema', 'warning');
                return;
            }

            // 1. CREAR EL FORMDATA (En lugar de un objeto simple)
            let formData = new FormData();

            // 2. AGREGAR LOS CAMPOS (Usando el prefijo "canjes." para que el Controlador lo mapee)
          /*  formData.append("canjes.IdCanje", 0);*/
            formData.append("canjes.IdTipoIncidencia", parseInt(idIncidencia));
            formData.append("canjes.DescripcionProblema", descripcion);
            formData.append("canjes.IdEstado", 3);
            formData.append("canjes.Monto", monto);
            formData.append("canjes.NumeroFactura", factura);
            formData.append("canjes.FechaFactura", fechaFactura);
            formData.append("canjes.IdCaja", idCaja);

            // 3. AGREGAR ARCHIVOS DEL INPUT
            const inputArchivos = document.getElementById('fArchivos');
            if (inputArchivos.files.length > 0) {
                for (let i = 0; i < inputArchivos.files.length; i++) {
                    formData.append("archivos", inputArchivos.files[i]);
                }
            }

            // 4. ENVIAR (Pasamos el formData directamente)
            enviarDatos(formData, "INSERT");
        }

        function enviarDatos(datosEntrada, accion) {
            let formData;

            // Si ya viene como FormData (desde crearCanje)
            if (datosEntrada instanceof FormData) {
                formData = datosEntrada;
                // Nos aseguramos de que lleve la Acción
                if (!formData.has("Accion")) formData.append("Accion", accion);
            }
            // Si viene como objeto (desde otras funciones)
            else {
                formData = new FormData();
                formData.append("Accion", accion);

                if (accion === "UPDATE" && state.canjeSeleccionado) {
                    formData.append("canjes.DescripcionProblema", state.canjeSeleccionado.DescripcionProblema || "");
                }

                for (let key in datosEntrada) {
                    formData.append("canjes." + key, datosEntrada[key]);
                }
            }

            $.ajax({
                url: '@Url.Action("GuardarCanje", "Canjes")',
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire('Éxito', res.mensaje, 'success');
                        $("#modalNuevoCanje").modal("hide");
                        refrescarTablaCanjes();
                        if (accion === "INSERT") {
                            $("#seccionDetalle").hide();
                            $("#detalleVacio").show();
                            state.canjeSeleccionado = null;
                            actualizarContadoresCards();
                            // Limpiar input de archivos después de insertar
                            $("#fArchivos").val("");
                        }
                    } else {
                        Swal.fire('Error', res.mensaje || 'Error al procesar', 'error');
                    }
                }
            });
        }
        // --- 7. UTILIDADES ---

        function monitorearMensajesNuevos() {
            // 1. Recopilamos todos los IDs de los canjes que están en la tabla
            let idsVisibles = [];
            $(".btn-ver").each(function () {
                const id = getId($(this).data("info"));
                if (id > 0) idsVisibles.push(id);
            });

            if (idsVisibles.length === 0) return;

            // 2. Pedimos el estado de TODOS de un solo golpe
            $.get('@Url.Action("ObtenerEstadoGlobalCanjes", "Canjes")', function (res) {
                let hayMensajesNuevosGlobal = false;

                res.forEach(estado => {
                    // Buscamos el ID visto en nuestro objeto de estado
                    const idVisto = state.ultimoIdComentarioVisto[estado.id] || 0;

                    // Si el ID remoto es mayor y el autor no soy yo...
                    if (estado.ultimoIdMsg > idVisto && estado.idAutorUltimo !== user.id) {
                        $(`#notif-${estado.id}`).removeClass("d-none");

                        // Si no es el canje que tengo abierto, activamos parpadeo
                        if (estado.id !== getId(state.canjeSeleccionado)) {
                            hayMensajesNuevosGlobal = true;
                        }
                    } else {
                        $(`#notif-${estado.id}`).addClass("d-none");
                    }
                });

                if (hayMensajesNuevosGlobal) {
                    iniciarParpadeoTitulo();
                } else {
                    // Si ya no hay mensajes nuevos en ningún canje (excepto quizás el abierto)
                    detenerParpadeoTitulo();
                }
            });
        }


        function guardarLecturaLocal(id, ultimoId) {
            // 1. Mantiene tu lógica actual de objeto JSON para las notificaciones (badges)
            state.ultimoIdComentarioVisto[id] = ultimoId;
            localStorage.setItem('chat_visto_' + user.id, JSON.stringify(state.ultimoIdComentarioVisto));

            // 2. Inserta aquí la nueva línea adaptada a tus variables:
            // idUsuarioLogueado -> user.id
            // idCanje -> id
            // ultimoIdMensaje -> ultimoId
            localStorage.setItem(`visto_canje_u${user.id}_c${id}`, ultimoId);
        }
        function formatearFecha(f) {
            if (!f || f.includes("0001-01-01")) return "---";
            let d = new Date(f);
            return isNaN(d) ? "---" : d.toLocaleString('es-NI');
        }

        function iniciarParpadeoTitulo() {
            if (state.intervaloPestaña) return;
            state.intervaloPestaña = setInterval(() => {
                document.title = (document.title === state.tituloOriginal) ? "✨ ACTUALIZACIÓN ✨" : state.tituloOriginal;
            }, 1000);
        }

        function detenerParpadeoTitulo() {
            clearInterval(state.intervaloPestaña);
            state.intervaloPestaña = null;
            document.title = state.tituloOriginal;
        }

